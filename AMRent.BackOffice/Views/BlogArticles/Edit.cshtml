@model AMRent.Data.Models.Database.BlogArticle

@{
    ViewData["Title"] = "Editar Artigo";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
    <li class="breadcrumb-item active"><a asp-controller="BlogArticles" asp-action="Index">Artigos</a></li>
}

<form asp-action="Edit" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <div class="row">
        @if (ViewData.ModelState.ErrorCount > 0)
        {
            <div class="col-md-12">
                <div class="card card-danger callout callout-danger">
                    <div asp-validation-summary="All" class="text-danger"></div>
                </div>
            </div>
        }
        <div class="col-md-12">
            <div class="card card-success card-outline">
                <div class="card-header">
                    <h3 class="card-title">Geral</h3>
                </div>
                <!-- /.card-header -->
                <div class="card-body">
                    <div class="row">
                        <div class="col-sm-3">
                            <div class="form-group form-group-label-on-top">
                                <label for="BlogArticleCategoryId">Categoria</label>
                                <select asp-for="BlogArticleCategoryId" class="form-control form-control-sm" asp-items="ViewBag.Categories">
                                    <option disabled selected></option>
                                </select>
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <div class="form-group form-group-label-on-top">
                                <label for="ViewCountIncrement">Incremento de Contador</label>
                                <input asp-for="ViewCountIncrement" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <div class="form-group form-group-label-on-top">
                                <label for="ViewCount">Contador de visualizações</label>
                                <input readonly="readonly" disabled="disabled" asp-for="ViewCount" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <div class="form-group form-group-label-on-top">
                                <label for="CreateDate">Data</label>
                                <input readonly="readonly" disabled="disabled" asp-for="CreateDate" class="form-control form-control-sm" />
                            </div>
                        </div>
                    </div>
                </div>
                <!-- /.card-body -->
            </div>
            <!-- /.card -->
        </div>
        <div class="col-md-12">
            @for (int i = 0; i < ViewBag.Languages.Count; i++)
            {
                int languageId = ViewBag.Languages[i].Id;
                var currentTranslation = Model.Translations?.FirstOrDefault(x => x.LanguageId == languageId);
                <input type="hidden" name="Translations[@i].LanguageId" value="@languageId" />
                <input type="hidden" name="Translations[@i].BlogArticleId" value="@(currentTranslation != null ? Model.Id : 0)" />
                <div class="card card-success card-outline">
                    <div class="card-header">
                        <h3 class="card-title">@ViewBag.Languages[i].Name</h3>
                    </div>
                    <!-- /.card-header -->
                    <div class="card-body">
                        <div class="row">
                            <div class="col-sm-12">
                                <div class="form-group form-group-label-on-top">
                                    <label for="Translations[@i].Title">Título</label>
                                    <input name="Translations[@i].Title" class="form-control form-control-sm" value="@(currentTranslation?.Title ?? "")" />
                                </div>
                            </div>
                            <div class="col-sm-12">
                                <div class="form-group form-group-label-on-top">
                                    <label for="Translations[@i].Text">Texto</label>
                                    <textarea rows="10" name="Translations[@i].Text" class="form-control form-control-sm">@(currentTranslation?.Text ?? "")</textarea>
                                </div>
                            </div>
                            <div class="col-sm-12">
                                <div class="form-group form-group-label-on-top">
                                    <label for="Translations[@i].YoutubeURL">URL Youtube</label>
                                    <input name="Translations[@i].YoutubeURL" class="form-control form-control-sm" value="@(currentTranslation?.YoutubeURL ?? "")" />
                                </div>
                            </div>
                            <div class="col-sm-12">
                                <div class="form-group form-group-label-on-top">
                                    <label for="Translations[@i].Tags">Tags</label>
                                    <input name="Translations[@i].Tags" class="form-control form-control-sm" value="@(currentTranslation?.Tags ?? "")" />
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- /.card-body -->
                </div>
                <!-- /.card -->
            }
        </div>
        <div class="col-md-12">
            <div class="card card-success card-outline">
                <div class="card-header">
                    <h3 class="card-title">Imagem (640px x 427px)</h3>
                </div>
                <!-- /.card-header -->
                <div class="card-body">
                    <div class="row">
                        <div class="col-sm-6" style="text-align: center;">
                            @if (!string.IsNullOrEmpty(Model?.ImagePath))
                            {
                                <img style="max-height: 300px; max-width: 50%;" src="@Model.ImagePath" />
                                <a asp-controller="BlogArticles" asp-action="DeleteImage" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">Apagar</a>
                            }
                        </div>
                        <div class="col-sm-6">
                            <div class="form-group form-group-label-on-top">
                                <label for="ImageFile">Upload</label>
                                <input type="file" name="ImageFile" class="form-control form-control-sm" />
                            </div>
                        </div>
                    </div>
                </div>
                <!-- /.card-body -->
            </div>
            <!-- /.card -->
        </div>
        <div class="col-md-12">
            <div class="card card-success card-outline">
                <div class="card-header">
                    <h3 class="card-title">Imagem de Topo (1920px x 600px)</h3>
                </div>
                <!-- /.card-header -->
                <div class="card-body">
                    <div class="row">
                        <div class="col-sm-6" style="text-align: center;">
                            @if (!string.IsNullOrEmpty(Model?.TopImagePath))
                            {
                                <img style="max-height: 300px; max-width: 50%;" src="@Model.TopImagePath" />
                            }
                        </div>
                        <div class="col-sm-6">
                            <div class="form-group form-group-label-on-top">
                                <label for="TopImageFile">Upload</label>
                                <input type="file" name="TopImageFile" class="form-control form-control-sm" />
                            </div>
                        </div>
                    </div>
                </div>
                <!-- /.card-body -->
            </div>
            <!-- /.card -->
        </div>
        <div class="col-md-12">
            <div class="card card-success card-outline">
                <div class="card-header">
                    <h3 class="card-title">Imagem da listagem (833px x 573px)</h3>
                </div>
                <!-- /.card-header -->
                <div class="card-body">
                    <div class="row">
                        <div class="col-sm-6" style="text-align: center;">
                            @if (!string.IsNullOrEmpty(Model?.ListImagePath))
                            {
                                <img style="max-height: 300px; max-width: 50%;" src="@Model.ListImagePath" />
                            }
                        </div>
                        <div class="col-sm-6">
                            <div class="form-group form-group-label-on-top">
                                <label for="ListImageFile">Upload</label>
                                <input type="file" name="ListImageFile" class="form-control form-control-sm" />
                            </div>
                        </div>
                    </div>
                </div>
                <!-- /.card-body -->
            </div>
            <!-- /.card -->
        </div>
    </div>
    <div class="row mb-2">
        <div class="col-sm-12">
            <button type="submit" class="btn btn-outline-success btn-sm float-right ml-2"><i class="far fa-save"></i> Gravar</button>
            <a asp-controller="BlogArticles" asp-action="Index" class="btn btn-outline-info btn-sm float-right ml-2"><i class="fas fa-undo-alt"></i> Voltar</a>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        $(function () {
            SetActiveMenu('menu-blog-articles', 'menu-content');
        });
    </script>
}