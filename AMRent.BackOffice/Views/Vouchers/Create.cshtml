@model AMRent.Data.Models.Database.Voucher

@{
    ViewData["Title"] = "Novo Voucher";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
    <li class="breadcrumb-item active"><a asp-controller="Vouchers" asp-action="Index">Vouchers</a></li>
}

<form asp-action="Create">
    <div class="row">
        @if (ViewData.ModelState.ErrorCount > 0)
        {
            <div class="col-md-12">
                <div class="card card-danger callout callout-danger">
                    <div asp-validation-summary="All" class="text-danger"></div>
                </div>
            </div>
        }
        <div class="col-md-6">
            <div class="card card-success card-outline">
                <div class="card-header">
                    <h3 class="card-title">Geral</h3>
                </div>
                <!-- /.card-header -->
                <div class="card-body">
                    <div class="row">
                        <div class="col-sm-3">
                            <div class="form-group form-group-label-on-top">
                                <label for="Code">Código</label>
                                <input asp-for="Code" class="form-control form-control-sm" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-3">
                            <div class="form-group form-group-label-on-top">
                                <label for="DiscountType">Tipo</label>
                                <select asp-for="DiscountType" class="form-control form-control-sm" asp-items="Html.GetEnumSelectList<AMRent.Data.Enums.DiscountTypes>()">
                                    <option disabled selected></option>
                                </select>
                            </div>
                        </div>
                        <div class="col-sm-3 value-input">
                            <div class="form-group form-group-label-on-top">
                                <label for="Value">Valor</label>
                                <input asp-for="Value" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-sm-3 extras-input">
                            <div class="form-group form-group-label-on-top">
                                <label for="ExtraIds">Extras</label>
                                <select asp-for="ExtraIds" class="form-control form-control-sm select2" multiple="multiple" style="width: 100%;" asp-items="ViewBag.Extras"></select>
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <div class="form-check">
                                <input asp-for="IsUsableForBackoffice" type="checkbox" class="form-check-input" />
                                <label for="IsUsableForBackoffice">Disponível para backoffice</label>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- /.card-body -->
            </div>
            <!-- /.card -->
        </div>
        <div class="col-md-6">
            <div class="card card-success card-outline">
                <div class="card-header">
                    <h3 class="card-title">Datas</h3>
                </div>
                <!-- /.card-header -->
                <div class="card-body">
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="form-group form-group-label-on-top">
                                <label for="ValidFromUtc">Activa a partir de</label>
                                <input asp-for="ValidFromUtc" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-group form-group-label-on-top">
                                <label for="ValidUntilUtc">Activa até</label>
                                <input asp-for="ValidUntilUtc" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-group form-group-label-on-top">
                                <label for="AppliesToBookingsMadeFromUtc">Início de aluguer a partir de</label>
                                <input asp-for="AppliesToBookingsMadeFromUtc" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="form-group form-group-label-on-top">
                                <label for="AppliesToBookingsMadeUntilUtc">Fim de aluguer até</label>
                                <input asp-for="AppliesToBookingsMadeUntilUtc" class="form-control form-control-sm" />
                            </div>
                        </div>
                    </div>
                </div>
                <!-- /.card-body -->
            </div>
            <!-- /.card -->
        </div>
    </div>
    <div class="row mb-2">
        <div class="col-sm-12">
            <button type="submit" class="btn btn-outline-success btn-sm float-right ml-2"><i class="far fa-save"></i> Gravar</button>
            <a asp-controller="Vouchers" asp-action="Index" class="btn btn-outline-info btn-sm float-right ml-2"><i class="fas fa-undo-alt"></i> Voltar</a>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        $(function () {
            SetActiveMenu('menu-vouchers', 'menu-renting');
            $('.select2').select2();

            $('#@(nameof(Model.DiscountType))').on('change', function () {
                RefreshVisibility();
            });

            RefreshVisibility();
        });

        function RefreshVisibility()
        {
            if ($("#@(nameof(Model.DiscountType))").val() == '@((int)AMRent.Data.Enums.DiscountTypes.Extra)')
            {
                $(".extras-input").show();
                $(".value-input").hide();
            }
            else
            {
                $(".extras-input").hide();
                $(".value-input").show();
            }
        }
    </script>
}