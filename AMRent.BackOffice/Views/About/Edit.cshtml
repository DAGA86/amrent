@model AMRent.Data.Models.Database.About

@{
    ViewData["Title"] = "Editar Sobre Nós";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
    <li class="breadcrumb-item active">Sobre Nós</li>
}

<form asp-action="Edit" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <div class="row">
        @if (ViewData.ModelState.ErrorCount > 0)
        {
            <div class="col-md-12">
                <div class="card card-danger callout callout-danger">
                    <div asp-validation-summary="All" class="text-danger"></div>
                </div>
            </div>
        }
        <div class="col-md-12">
            <div class="card card-success card-outline">
                <div class="card-header">
                    <h3 class="card-title">Imagem (1164px x 1011px)</h3>
                </div>
                <!-- /.card-header -->
                <div class="card-body">
                    <div class="row">
                        <div class="col-sm-6" style="text-align: center;">
                            @if (!string.IsNullOrEmpty(Model.ImagePath))
                            {
                                <img style="max-height: 300px; max-width: 50%;" src="@Model.ImagePath" />
                            }
                        </div>
                        <div class="col-sm-6">
                            <div class="form-group form-group-label-on-top">
                                <label for="ImageFile">Upload</label>
                                <input type="file" name="ImageFile" class="form-control form-control-sm" />
                            </div>
                        </div>
                    </div>
                </div>
                <!-- /.card-body -->
            </div>
            <!-- /.card -->
        </div>
        @for (int i = 0; i < ViewBag.Languages.Count; i++)
        {
            int languageId = ViewBag.Languages[i].Id;
            var currentTranslation = Model.Translations?.FirstOrDefault(x => x.LanguageId == languageId);
            <div class="col-md-6">
                <input type="hidden" name="Translations[@i].LanguageId" value="@languageId" />
                <input type="hidden" name="Translations[@i].AboutId" value="@(currentTranslation != null ? Model.Id : 0)" />
                <div class="card card-success card-outline">
                    <div class="card-header">
                        <h3 class="card-title">@ViewBag.Languages[i].Name</h3>
                    </div>
                    <!-- /.card-header -->
                    <div class="card-body">
                        <div class="row">
                            <div class="col-sm-6">
                                <div class="form-group form-group-label-on-top">
                                    <label for="Translations[@i].Title">Título</label>
                                    <input name="Translations[@i].Title" class="form-control form-control-sm" value="@(currentTranslation?.Title ?? "")" />
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="form-group form-group-label-on-top">
                                    <label for="Translations[@i].ImageSideText">Texto imagem (lateral)</label>
                                    <input name="Translations[@i].ImageSideText" class="form-control form-control-sm" value="@(currentTranslation?.ImageSideText ?? "")" />
                                </div>
                            </div>
                            <div class="col-sm-12">
                                <div class="form-group form-group-label-on-top">
                                    <label for="Translations[@i].Text">Texto</label>
                                    <textarea rows="10" name="Translations[@i].Text" class="form-control form-control-sm">@(currentTranslation?.Text ?? "")</textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- /.card-body -->
                </div>
                <!-- /.card -->
            </div>
        }
    </div>
    <div class="row mb-2">
        <div class="col-sm-12">
            <button type="submit" class="btn btn-outline-success btn-sm float-right ml-2"><i class="far fa-save"></i> Gravar</button>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-info btn-sm float-right ml-2"><i class="fas fa-undo-alt"></i> Voltar</a>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        $(function () {
            SetActiveMenu('menu-about', 'menu-content');
        });
    </script>
}