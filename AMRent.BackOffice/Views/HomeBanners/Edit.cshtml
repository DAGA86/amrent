@model AMRent.Data.Models.Database.HomeBanner

@{
    ViewData["Title"] = "Editar Banner homepage";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
    <li class="breadcrumb-item active"><a asp-controller="HomeBanners" asp-action="Index">Banners homepage</a></li>
}

<form asp-action="Edit" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <div class="row">
        @if (ViewData.ModelState.ErrorCount > 0)
        {
            <div class="col-md-12">
                <div class="card card-danger callout callout-danger">
                    <div asp-validation-summary="All" class="text-danger"></div>
                </div>
            </div>
        }
        <div class="col-md-12">
            <div class="card card-success card-outline">
                <div class="card-header">
                    <h3 class="card-title">Geral</h3>
                </div>
                <!-- /.card-header -->
                <div class="card-body">
                    <div class="row">
                        <div class="col-sm-6">
                            <div class="form-group form-group-label-on-top">
                                <label for="Name">Nome</label>
                                <input asp-for="Name" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <div class="form-group form-group-label-on-top">
                                <label for="ValidFromUtc">Mostrar a partir de</label>
                                <input asp-for="ValidFromUtc" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <div class="form-group form-group-label-on-top">
                                <label for="ValidUntilUtc">Mostrar até</label>
                                <input asp-for="ValidUntilUtc" class="form-control form-control-sm" />
                            </div>
                        </div>
                    </div>
                </div>
                <!-- /.card-body -->
            </div>
            <!-- /.card -->
        </div>
        <div class="col-md-12">
            @for (int i = 0; i < ViewBag.Languages.Count; i++)
            {
                int languageId = ViewBag.Languages[i].Id;
                var currentTranslation = Model.Translations?.FirstOrDefault(x => x.LanguageId == languageId);
                <input type="hidden" name="Translations[@i].LanguageId" value="@languageId" />
                <input type="hidden" name="Translations[@i].HomeBannerId" value="@(currentTranslation != null ? Model.Id : 0)" />
                <div class="card card-success card-outline">
                    <div class="card-header">
                        <h3 class="card-title">@ViewBag.Languages[i].Name</h3>
                    </div>
                    <!-- /.card-header -->
                    <div class="card-body">
                        <div class="row">
                            <div class="col-sm-12">
                                <div class="form-group form-group-label-on-top">
                                    <label for="Translations[@i].URL">URL</label>
                                    <input name="Translations[@i].URL" class="form-control form-control-sm" value="@(currentTranslation?.URL ?? "")" />
                                </div>
                            </div>
                            <div class="col-sm-6" style="text-align: center;">
                                @if (!string.IsNullOrEmpty(currentTranslation?.ImagePath))
                                {
                                    <img style="max-height: 300px; max-width: 50%;" src="@currentTranslation.ImagePath" />
                                }
                            </div>
                            <div class="col-sm-6">
                                <div class="form-group form-group-label-on-top">
                                    <label for="ImageFile_@(ViewBag.Languages[i].Code)_@(ViewBag.Languages[i].CountryCode)">Imagem (1922px x 600px)</label>
                                    <input type="file" name="ImageFile_@(ViewBag.Languages[i].Code)_@(ViewBag.Languages[i].CountryCode)" class="form-control form-control-sm" />
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- /.card-body -->
                </div>
                <!-- /.card -->
            }
        </div>
    </div>
    <div class="row mb-2">
        <div class="col-sm-12">
            <button type="submit" class="btn btn-outline-success btn-sm float-right ml-2"><i class="far fa-save"></i> Gravar</button>
            <a asp-controller="HomeBanners" asp-action="Index" class="btn btn-outline-info btn-sm float-right ml-2"><i class="fas fa-undo-alt"></i> Voltar</a>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        $(function () {
            SetActiveMenu('menu-home-banners', 'menu-content');
        });
    </script>
}