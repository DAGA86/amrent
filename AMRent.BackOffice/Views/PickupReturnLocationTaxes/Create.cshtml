@model AMRent.Data.Models.Database.PickupReturnLocationTax

@{
    ViewData["Title"] = "Nova Taxa de recolha/devolução (local)";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
    <li class="breadcrumb-item active"><a asp-controller="PickupReturnLocationTaxes" asp-action="Index">Taxas de recolha/devolução (local)</a></li>
}

<form asp-action="Create">
    <div class="row">
        @if (ViewData.ModelState.ErrorCount > 0)
        {
            <div class="col-md-12">
                <div class="card card-danger callout callout-danger">
                    <div asp-validation-summary="All" class="text-danger"></div>
                </div>
            </div>
        }
        <div class="col-md-12">
            <div class="card card-success card-outline">
                <div class="card-header">
                    <h3 class="card-title">Geral</h3>
                </div>
                <!-- /.card-header -->
                <div class="card-body">
                    <div class="row">
                        <div class="col-sm-4">
                            <div class="form-group form-group-label-on-top">
                                <label for="PickupReturnLocationId">Local de recolha/devolução</label>
                                <select asp-for="PickupReturnLocationId" class="form-control form-control-sm" asp-items="ViewBag.Locations">
                                    <option disabled selected></option>
                                </select>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="form-group form-group-label-on-top">
                                <label for="Days">Dias</label>
                                <input asp-for="Days" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="form-group form-group-label-on-top">
                                <label for="Value">Valor</label>
                                <input asp-for="Value" class="form-control form-control-sm" />
                            </div>
                        </div>
                    </div>
                </div>
                <!-- /.card-body -->
            </div>
            <!-- /.card -->
        </div>
    </div>
    <div class="row mb-2">
        <div class="col-sm-12">
            <button type="submit" class="btn btn-outline-success btn-sm float-right ml-2"><i class="far fa-save"></i> Gravar</button>
            <a asp-controller="PickupReturnLocationTaxes" asp-action="Index" class="btn btn-outline-info btn-sm float-right ml-2"><i class="fas fa-undo-alt"></i> Voltar</a>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        $(function () {
            SetActiveMenu('menu-pickup-return-location-taxes', 'menu-renting');
        });
    </script>
}