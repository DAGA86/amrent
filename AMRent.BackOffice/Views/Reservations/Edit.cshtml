    @if (Model.Changes.Any() || Model.DataProtectionConsents.Any(x => x.DataProtectionConsentReservationChanges.Any()))
    {
        <div class="row mb-2">
            <div class="col-md-12">
                <div class="card card-success card-outline">
                    <div class="card-header">
                        <h3 class="card-title">Histórico</h3>
                    </div>
                    <!-- /.card-header -->
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-12">
                                <table class="table table-striped">
                                    <thead>
                                        <tr>
                                            <th>Campo</th>
                                            <th>Valor Anterior</th>
                                            <th>Valor Novo</th>
                                            <th>Data</th>
                                            <th>Utilizador</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model.Changes.Any())
                                        {
                                            foreach (var changeItem in Model.Changes.OrderByDescending(x => x.ChangeDateTime).ThenBy(x => x.FieldName))
                                            {
                                                <tr>
                                                    <td>@changeItem.FieldName</td>
                                                    <td>@changeItem.OldValue</td>
                                                    <td>@changeItem.NewValue</td>
                                                    <td>@changeItem.ChangeDateTime</td>
                                                    <td>@changeItem.User.Username</td>
                                                </tr>
                                            }
                                        }
                                        @if (Model.DataProtectionConsents.Any(x => x.DataProtectionConsentReservationChanges.Any()))
                                        {
                                            foreach (var dataProtectionConsents in Model.DataProtectionConsents.Where(x => x.DataProtectionConsentReservationChanges.Any()))
                                            {
                                                foreach (var changeItem in dataProtectionConsents.DataProtectionConsentReservationChanges.OrderByDescending(x => x.ChangeDateTime).ThenBy(x => x.FieldName))
                                                {
                                                    <tr>
                                                        <td>@changeItem.FieldName</td>
                                                        <td>@changeItem.OldValue</td>
                                                        <td>@changeItem.NewValue</td>
                                                        <td>@changeItem.ChangeDateTime</td>
                                                        <td>@changeItem.User.Username</td>
                                                    </tr>
                                                }
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</form>

@section Scripts {
    <!-- Bootstrap Switch -->
    <script src="~/lib/bootstrap-switch/js/bootstrap-switch.min.js"></script>
    <script>
        $(function () {
            SetActiveMenu('menu-reservations', 'menu-renting');

            if ($('#PickupLocationId').val() == '-1') {
                $('#custom-pickup-location').show();
            }
            if ($('#ReturnLocationId').val() == '-1') {
                $('#custom-return-location').show();
            }

            $("input[max='1']").on("input", function () {
                if ($(this).val() > 1) {
                    $(this).val(1);
                }
            });

            $("input[data-bootstrap-switch]").each(function(){
                $(this).bootstrapSwitch();
                $(this).on('switchChange.bootstrapSwitch', function(event, state) {
                    $(this).val(state);
                    if (state)
                    {
                        $('.AdvancePartialPayment').show();
                    }
                    else
                    {
                        $('.AdvancePartialPayment').hide();
                    }
                });
            })
            if ($('#HasAdvancePartialPayment').is(':checked'))
            {
                $('.AdvancePartialPayment').show();
            }

            $('#PickupLocationId').change(function () {
                if ($(this).val() == '-1') {
                    $('#custom-pickup-location').show();
                } else {
                    $('#custom-pickup-location').hide();
                }
            });

            $('#ReturnLocationId').change(function () {
                if ($(this).val() == '-1') {
                    $('#custom-return-location').show();
                } else {
                    $('#custom-return-location').hide();
                }
            });

            $('.trigger-refresh').change(function () {
                $('#IsRefresh').val('true');
            });
        });

        function Refresh() {
            $('#IsRefresh').val('true');
            $('#reservation-edit-form').submit();
        }

        function ValidateSubmit() {
            $('input').removeClass("input-validation-error");
            $('select').removeClass("input-validation-error");
            var valid = true;
            if ($('#Status').val() == '@(AMRent.Data.Enums.ReservationStatus.Confirmed)' || $('#Status').val() == '@(AMRent.Data.Enums.ReservationStatus.Finished)')
            {
                if ($('#DriverIdentityType').val() == '' || $('#DriverIdentityType').val() == null) {
                    $('#DriverIdentityType').addClass("is-invalid");
                    valid = false;
                } else {
                    if ($('#DriverIdentityType').val() == '@(nameof(AMRent.Data.Enums.IdentityType.CitizenCard))'
                        && $('#DriverIdentityCountryId option:selected').text() == 'Portugal')
                    {
                        if ($('#DriverVatNumber').val() == '' || $('#DriverVatNumber').val() == null) {
                            $('#DriverVatNumber').addClass("is-invalid");
                            valid = false;
                        } else {
                            $('#DriverVatNumber').removeClass("is-invalid");
                        }
                    }
                    else{
                        $('#DriverVatNumber').removeClass("is-invalid");
                    }
                    $('#DriverIdentityType').removeClass("is-invalid");
                }
                if ($('#DriverIdentityNumber').val() == '' || $('#DriverIdentityNumber').val() == null) {
                    $('#DriverIdentityNumber').addClass("is-invalid");
                    valid = false;
                } else {
                    $('#DriverIdentityNumber').removeClass("is-invalid");
                }
                if ($('#DriverIdentityCountryId').val() == '' || $('#DriverIdentityCountryId').val() == null) {
                    $('#DriverIdentityCountryId').addClass("is-invalid");
                    valid = false;
                } else {
                    $('#DriverIdentityCountryId').removeClass("is-invalid");
                }
                $('.birth-date').each(function () {
                    if ($(this).val() != '' || $(this).val() != null) {
                        const today = new Date();
                        const thresholdDate = new Date(today.getFullYear() - 18, today.getMonth(), today.getDate());
                        const birthDateValue = new Date($(this).val());
                        if (birthDateValue > thresholdDate) {
                            $(this).addClass("is-invalid");
                            valid = false;
                        } else {
                            $(this).removeClass("is-invalid");
                        }
                    }
                });
            }

            return valid;
        }

        function SubmitForm() {
            if (ValidateSubmit())
            {
                $('#reservation-edit-form').submit();
            }
        }

        $('#PickupLocationId').on('change', function () {
            Refresh();
        });

        $('#ReturnLocationId').on('change', function () {
            Refresh();
        });
    </script>
}