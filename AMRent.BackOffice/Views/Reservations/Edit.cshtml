@using AMRent.Data.Models.Database
@model AMRent.Data.Models.Database.Reservation

@{
    ViewData["Title"] = "Editar Reserva";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
    <li class="breadcrumb-item active"><a asp-controller="Reservations" asp-action="Index">Reservas</a></li>
}

<form asp-action="Edit" id="reservation-edit-form">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="Number" />
    <input type="hidden" asp-for="CreateDate" />
    <input type="hidden" asp-for="Source" />
    <input type="hidden" asp-for="CarSegmentId" />
    <input type="hidden" asp-for="CarSegmentCost" />
    <input type="hidden" asp-for="PickupCost" />
    <input type="hidden" asp-for="ReturnCost" />
    <input type="hidden" asp-for="InsuranceCost" />
    <input type="hidden" asp-for="InsuranceExcess" />
    <input type="hidden" asp-for="TotalCost" />
    <input type="hidden" asp-for="PickupDateTime" />
    <input type="hidden" asp-for="ReturnDateTime" />
    <input type="hidden" asp-for="CampaignId" />
    <input type="hidden" asp-for="VoucherId" />
    <input type="hidden" asp-for="CustomerId" />
    <input type="hidden" asp-for="CustomPickupLocationName" />
    <input type="hidden" asp-for="CustomReturnLocationName" />
    <input type="hidden" asp-for="SourceQuotationId" />
    <input type="hidden" name="IsRefresh" id="IsRefresh" value="false" />
    <input type="hidden" name="SendEmail" id="SendEmail" value="false" />
    <div class="row">
        @if (ViewData.ModelState.ErrorCount > 0)
        {
            <div class="col-md-12">
                <div class="card card-danger callout callout-danger">
                    <div asp-validation-summary="All" class="text-danger"></div>
                </div>
            </div>
        }
        <div class="col-md-12">
            <div class="card card-success card-outline">
                <div class="card-header">
                    <h3 class="card-title">Geral</h3>
                </div>
                <!-- /.card-header -->
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group form-group-label-on-top">
                                <label for="UserId">Colaborador</label>
                                <select asp-for="AssignedUserId" class="form-control form-control-sm" asp-items="ViewBag.Users">
                                    <option disabled selected></option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group form-group-label-on-top">
                                <label>Número</label>
                                <input type="text" value="@Model.Number" disabled="disabled" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group form-group-label-on-top">
                                <label>Registo</label>
                                <input type="text" value="@Model.CreateDate.ToString("dd/MM/yyyy HH:mm")" disabled="disabled" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group form-group-label-on-top">
                                <label for="Source">Origem</label>
                                <select asp-for="Source" disabled="disabled" class="form-control form-control-sm" asp-items="ViewBag.ReservationSources">
                                    <option disabled selected></option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group form-group-label-on-top">
                                <label for="Status">Estado</label>
                                <select asp-for="Status" class="form-control form-control-sm" asp-items="ViewBag.ReservationStatus">
                                    <option disabled selected></option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group form-group-label-on-top">
                                <label for="CarSegmentId">Segmento</label>
                                <select asp-for="CarSegmentId" disabled="disabled" class="form-control form-control-sm" asp-items="ViewBag.CarSegments">
                                    <option disabled selected></option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group form-group-label-on-top">
                                <label>Código</label>
                                <input type="text" disabled="disabled" class="form-control form-control-sm" value="@Model.CarSegment.Code" />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group form-group-label-on-top">
                                <label>Combustível</label>
                                <input type="text" disabled="disabled" class="form-control form-control-sm" value="@Model.CarSegment.CarFuel.Translations.FirstOrDefault().Name" />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group form-group-label-on-top">
                                <label>Assentos</label>
                                <input type="text" disabled="disabled" class="form-control form-control-sm" value="@Model.CarSegment.Seats" />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group form-group-label-on-top">
                                <label for="InsuranceLevelId">Cobertura</label>
                                <select asp-for="InsuranceLevelId" class="form-control form-control-sm" asp-items="ViewBag.InsuranceLevels">
                                    <option disabled selected></option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- /.card-body -->
            </div>
            <!-- /.card -->
        </div>
        <div class="col-md-12">
            <div class="card card-success card-outline">
                <div class="card-header">
                    <h3 class="card-title">Custos</h3>
                </div>
                <!-- /.card-header -->
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-2">
                            <div class="form-group form-group-label-on-top">
                                <label for="PaymentType">Meio de pagamento</label>
                                <select asp-for="PaymentType" class="form-control form-control-sm" asp-items="ViewBag.PaymentTypes">
                                    <option disabled selected></option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group form-group-label-on-top">
                                <label for="PaymentStatus">Estado</label>
                                <select asp-for="PaymentStatus" class="form-control form-control-sm" asp-items="ViewBag.PaymentStatus"></select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group form-group-label-on-top">
                                <label for="HasAdvancePartialPayment">Sinal</label>
                                <input type="checkbox" asp-for="HasAdvancePartialPayment" data-bootstrap-switch data-on-text="Sim" data-off-text="Não">
                            </div>
                        </div>
                        <div class="col-md-2 AdvancePartialPayment" style="display: none;">
                            <div class="form-group form-group-label-on-top">
                                <label for="AdvancePartialPaymentPaymentType">Meio de pagamento (sinal)</label>
                                <select asp-for="AdvancePartialPaymentPaymentType" class="form-control form-control-sm" asp-items="ViewBag.PaymentTypes">
                                    <option disabled selected></option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2 AdvancePartialPayment" style="display: none;">
                            <div class="form-group form-group-label-on-top">
                                <label for="AdvancePartialPaymentValue">Valor (sinal)</label>
                                <input type="text" asp-for="AdvancePartialPaymentValue" class="form-control form-control-sm" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-2">
                            <div class="form-group form-group-label-on-top">
                                <label>Segmento</label>
                                <input type="text" value="@(Model.CarSegmentCost)" disabled="disabled" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group form-group-label-on-top">
                                <label>Recolha</label>
                                <input type="text" value="@(Model.PickupCost)" disabled="disabled" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group form-group-label-on-top">
                                <label>Devolução</label>
                                <input type="text" value="@(Model.ReturnCost)" disabled="disabled" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group form-group-label-on-top">
                                <label>Cobertura</label>
                                <input type="text" value="@(Model.InsuranceCost)" disabled="disabled" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group form-group-label-on-top">
                                <label>Franquia</label>
                                <input type="text" value="@(Model.InsuranceExcess)" disabled="disabled" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group form-group-label-on-top">
                                <label>Extras</label>
                                <input type="text" value="@(Model.Extras.Sum(x => x.UnitValue * x.Quantity))" readonly class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group form-group-label-on-top">
                                <label>Serviços</label>
                                <input type="text" value="@(Model.Services.Sum(x => x.Value))" readonly class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group form-group-label-on-top">
                                <label>Taxas</label>
                                <input type="text" value="@(Model.PickupReturnTemporaryTaxes.Sum(x => x.UnitValue * x.Quantity))" readonly class="form-control form-control-sm" />
                            </div>
                        </div>
                        @if (Model.TotalCost != Model.CarSegmentCost + Model.PickupCost + Model.ReturnCost + Model.InsuranceCost + Model.Extras.Sum(x => x.UnitValue * x.Quantity) + Model.Services.Sum(x => x.Value) + Model.PickupReturnTemporaryTaxes.Sum(x => x.UnitValue * x.Quantity))
                        {
                            <div class="col-md-2">
                                <div class="form-group form-group-label-on-top">
                                    <label>Total sem desconto</label>
                                    <input type="text" value="@(Model.CarSegmentCost + Model.PickupCost + Model.ReturnCost + Model.InsuranceCost + Model.Extras.Sum(x => x.UnitValue * x.Quantity) + Model.Services.Sum(x => x.Value) + Model.PickupReturnTemporaryTaxes.Sum(x => x.UnitValue * x.Quantity))" readonly class="form-control form-control-sm" />
                                </div>
                            </div>
                        }
                        <div class="col-md-2">
                            <div class="form-group form-group-label-on-top">
                                <label>Total</label>
                                <input type="text" value="@(Model.TotalCost)" readonly class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group form-group-label-on-top">
                                <label>Total (manual)</label>
                                <input asp-for="TotalCostOverride" class="form-control form-control-sm" />
                            </div>
                        </div>
                    </div>
                </div>
                <!-- /.card-body -->
            </div>
            <!-- /.card -->
        </div>
        <div class="col-md-6">
            <div class="card card-success card-outline">
                <div class="card-header">
                    <h3 class="card-title">Recolha / Entrega</h3>
                </div>
                <!-- /.card-header -->
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group form-group-label-on-top">
                                <label for="PickupLocationId">Local de recolha</label>
                                <select asp-for="PickupLocationId" class="form-control form-control-sm" asp-items="ViewBag.PickupLocations">
                                    <option disabled selected></option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3" style="display: none;" id="custom-pickup-location">
                            <div class="form-group form-group-label-on-top">
                                <label for="CustomPickupLocationName">Local de recolha (outro)</label>
                                <input asp-for="CustomPickupLocationName" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group form-group-label-on-top">
                                <label for="PickupDateTime">Data de recolha</label>
                                <input disabled="disabled" value="@Model.PickupDateTime.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group form-group-label-on-top">
                                <label>Hora</label>
                                <input type="time" id="PickupTime" name="PickupTime" class="form-control form-control-sm" value="@Model.PickupDateTime.ToString("HH:mm")" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group form-group-label-on-top">
                                <label for="ReturnLocationId">Local de devolução</label>
                                <select asp-for="ReturnLocationId" class="form-control form-control-sm" asp-items="ViewBag.ReturnLocations">
                                    <option disabled selected></option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3" style="display: none;" id="custom-return-location">
                            <div class="form-group form-group-label-on-top">
                                <label for="CustomReturnLocationName">Local de devolução (outro)</label>
                                <input asp-for="CustomReturnLocationName" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group form-group-label-on-top">
                                <label for="ReturnDateTime">Data de devolução</label>
                                <input disabled="disabled" value="@Model.ReturnDateTime.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group form-group-label-on-top">
                                <label>Hora</label>
                                <input type="time" id="ReturnTime" name="ReturnTime" class="form-control form-control-sm" value="@Model.ReturnDateTime.ToString("HH:mm")" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-2">
                            <div class="form-group form-group-label-on-top">
                                <label for="TotalDays">Dias</label>
                                <input asp-for="TotalDays" disabled="disabled" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group form-group-label-on-top">
                                <label for="FlightNumber">Número de voo</label>
                                <input asp-for="FlightNumber" class="form-control form-control-sm" />
                            </div>
                        </div>
                    </div>
                </div>
                <!-- /.card-body -->
            </div>
            <!-- /.card -->
        </div>
        <div class="col-md-6">
            <div class="card card-success card-outline">
                <div class="card-header">
                    <h3 class="card-title">Outros</h3>
                </div>
                <!-- /.card-header -->
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group form-group-label-on-top">
                                <label for="VoucherId">Voucher</label>
                                <select asp-for="VoucherId" disabled="disabled" class="form-control form-control-sm" asp-items="ViewBag.Vouchers">
                                    <option disabled selected></option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group form-group-label-on-top">
                                <label for="CampaignId">Campanha</label>
                                <select asp-for="CampaignId" disabled="disabled" class="form-control form-control-sm" asp-items="ViewBag.Campaigns">
                                    <option disabled selected></option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group form-group-label-on-top">
                                <label for="LanguageId">Lingua para comunicações</label>
                                <select asp-for="LanguageId" class="form-control form-control-sm" asp-items="ViewBag.Languages"></select>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="form-group form-group-label-on-top">
                                <label for="PickupLocationId">Comentários</label>
                                <textarea rows="3" asp-for="Comments" class="form-control form-control-sm"></textarea>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- /.card-body -->
            </div>
            <!-- /.card -->
        </div>
        <div class="col-md-12">
            <div class="card card-success card-outline">
                <div class="card-header">
                    <h3 class="card-title">Condutor</h3>
                </div>
                <!-- /.card-header -->
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group form-group-label-on-top">
                                <label for="DriverName">Nome</label>
                                <input asp-for="DriverName" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group form-group-label-on-top">
                                <label for="DriverBirthDate">Data de nascimento</label>
                                <input asp-for="DriverBirthDate" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group form-group-label-on-top">
                                <label for="DriverEmailAddress">Email</label>
                                <input asp-for="DriverEmailAddress" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group form-group-label-on-top">
                                <label for="DriverTelephonePrefixCountryId">Indicativo</label>
                                <select asp-for="DriverTelephonePrefixCountryId" class="form-control form-control-sm" asp-items="ViewBag.DriverTelehonePrefixCountries">
                                    <option disabled selected></option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group form-group-label-on-top">
                                <label for="DriverTelephone">Telefone</label>
                                <input asp-for="DriverTelephone" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group form-group-label-on-top">
                                <label for="DriverIdentificationCountryId">País de identificação</label>
                                <select asp-for="DriverIdentityCountryId" class="form-control form-control-sm" asp-items="ViewBag.DriverIdentificationCountries">
                                    <option disabled selected></option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group form-group-label-on-top">
                                <label for="DriverIdentityType">Tipo de identificação</label>
                                <select asp-for="DriverIdentityType" class="form-control form-control-sm" asp-items="ViewBag.IdentityTypes">
                                    <option disabled selected></option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group form-group-label-on-top">
                                <label for="DriverIdentificationNumber">Número de identificação</label>
                                <input asp-for="DriverIdentityNumber" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group form-group-label-on-top">
                                <label for="DriverVatNumber">NIF</label>
                                <input asp-for="DriverVatNumber" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group form-group-label-on-top">
                                <label for="DriverLicenseCountryId">País de carta de condução</label>
                                <select asp-for="DriverLicenseCountryId" class="form-control form-control-sm" asp-items="ViewBag.DriverLicenceCountries">
                                    <option disabled selected></option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group form-group-label-on-top">
                                <label for="DriverLicenseNumber">Número de carta de condução</label>
                                <input asp-for="DriverLicenseNumber" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group form-group-label-on-top">
                                <label for="DriverLicenseDate">Emissão de carta de condução</label>
                                <input asp-for="DriverLicenseDate" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group form-group-label-on-top">
                                <label for="DriverLicenseExpireDate">Validade de carta de condução</label>
                                <input asp-for="DriverLicenseExpireDate" class="form-control form-control-sm" />
                            </div>
                        </div>
                    </div>
                </div>
                <!-- /.card-body -->
            </div>
            <!-- /.card -->
        </div>
        <div class="col-md-3">
            <div class="card card-success card-outline">
                <div class="card-header">
                    <h3 class="card-title">Taxas</h3>
                </div>
                <!-- /.card-header -->
                <div class="card-body">
                    <div class="row">
                        @for (int i = 0; i < Model.PickupReturnTemporaryTaxes.Count; i++)
                        {
                            <input type="hidden" asp-for="PickupReturnTemporaryTaxes[i].ReservationId" />
                            <input type="hidden" asp-for="PickupReturnTemporaryTaxes[i].PickupReturnTemporaryTaxId" />
                            <input type="hidden" asp-for="PickupReturnTemporaryTaxes[i].UnitValue" />
                            <input type="hidden" asp-for="PickupReturnTemporaryTaxes[i].Quantity" />
                            <div class="col-md-2">
                                <div class="form-group form-group-label-on-top">
                                    <label for="PickupReturnTemporaryTaxes[@i].Quantity">Qtd</label>
                                    <input value="@(Model.PickupReturnTemporaryTaxes[i].Quantity)" disabled="disabled" class="form-control form-control-sm" />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group form-group-label-on-top">
                                    <label>Valor</label>
                                    <input value="@(Model.PickupReturnTemporaryTaxes[i].UnitValue * Model.PickupReturnTemporaryTaxes[i].Quantity)" disabled="disabled" class="form-control form-control-sm" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group form-group-label-on-top">
                                    <label>Taxa</label>
                                    <input value="@(Model.PickupReturnTemporaryTaxes[i].PickupReturnTemporaryTax.Translations.FirstOrDefault().Name)" disabled="disabled" class="form-control form-control-sm" />
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <!-- /.card-body -->
            </div>
            <!-- /.card -->
        </div>
        <div class="col-md-3">
            <div class="card card-success card-outline">
                <div class="card-header">
                    <h3 class="card-title">Serviços (custos)</h3>
                    <button onclick="Refresh();" class="btn btn-outline-success btn-sm float-right ml-2"><i class="fas fa-sync-alt"></i> Actualizar</button>
                </div>
                <!-- /.card-header -->
                <div class="card-body">
                    <div class="row">
                        @for (int i = 0; i < Model.Services.Count; i++)
                        {
                            <div class="col-md-12">
                                <input type="hidden" asp-for="Services[i].ReservationId" />
                                <input type="hidden" asp-for="Services[i].ServiceId" />
                                <div class="form-group form-group-label-on-top">
                                    <label for="Services[@i].Value">@Model.Services[i].Service.Translations.FirstOrDefault().Name</label>
                                    <input asp-for="Services[i].Value" min="0" class="form-control form-control-sm trigger-refresh" />
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <!-- /.card-body -->
            </div>
            <!-- /.card -->
        </div>
