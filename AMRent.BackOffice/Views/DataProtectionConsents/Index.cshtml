@{
    ViewData["Title"] = "Consentimentos";
}

@section Breadcrumb {
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active"><a asp-controller="DataProtectionConsents" asp-action="Index">Consentimentos</a></li>
}

<div class="row mb-2">
    <div class="col-sm-12">
        <a class="btn btn-outline-success btn-sm float-right ml-2" asp-controller="DataProtectionConsents" asp-action="Create"><i class="fas fa-plus"></i> Novo</a>
    </div>
</div>
<div class="row">
    <div class="col-12">
        <div class="card card-success card-outline">
            <div class="card-body">
                <table id="datatable" class="table table-bordered table-striped" style="width:100%">
                    <thead>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    $(function () {
        var deleteUrl = '';
        $('#datatable').DataTable({
            lengthMenu: [50, 100, 250, 500],
            processing: true,
            serverSide: true,
            ajax: {
                url: '/DataProtectionConsents/Get',
                method: 'Post'
            },
                columnDefs: [
                { title: 'Ordem', targets: 0 },
                { title: 'Texto', targets: 1 },
                {
                    targets: 2, sortable: false, searchable: false, render: function (data, type, row) {
                        var result = '';
                        result += '<a class="btn btn-info btn-xs btn-xs-square" href="/DataProtectionConsents/Edit/' + data + '"><i class="fas fa-edit"></i></a>';
                        if (row.isActive) {
                            result += '<a class="btn btn-danger btn-xs btn-xs-square ml-2" href="/DataProtectionConsents/Deactivate/' + data + '"><i class="fas fa-eye-slash"></i></a>';
                        }
                        else {
                            result += '<a class="btn btn-success btn-xs btn-xs-square ml-2" href="/DataProtectionConsents/Activate/' + data + '"><i class="fas fa-eye"></i></a>';
                        }
                        if (!row.isLowestSortNumber){
                            result += '<a class="btn btn-secondary btn-xs btn-xs-square ml-2" href="/DataProtectionConsents/SortUp/' + row.id + '"><i class="fas fa-arrow-up"></i></a>';
                        }
                        if (!row.isHighestSortNumber) {
                            result += '<a class="btn btn-secondary btn-xs btn-xs-square ml-2" href="/DataProtectionConsents/SortDown/' + row.id + '"><i class="fas fa-arrow-down"></i></a>';
                        }
                        return result;
                    }
                },
            ],
            columns: [
                { data: 'sortNumber' },
                { data: 'text' },
                { data: 'id' },
                { data: 'isActive', visible: false },
                { data: 'isLowestSortNumber', visible: false },
                { data: 'isHighestSortNumber', visible: false }
            ],
            language: dataTablesLanguage
        });

        SetActiveMenu('menu-consents', 'menu-content');
    });
</script>
}
