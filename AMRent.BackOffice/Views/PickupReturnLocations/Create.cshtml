@model AMRent.Data.Models.Database.PickupReturnLocation

@{
    ViewData["Title"] = "Novo Local de Recolha e Devolução";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
    <li class="breadcrumb-item active"><a asp-controller="PickupReturnLocations" asp-action="Index">Locais de Recolha e Devolução</a></li>
}

<form asp-action="Create">
    <div class="row">
        @if (ViewData.ModelState.ErrorCount > 0)
        {
            <div class="col-md-12">
                <div class="card card-danger callout callout-danger">
                    <div asp-validation-summary="All" class="text-danger"></div>
                </div>
            </div>
        }
        <div class="col-md-12">
            <div class="card card-success card-outline">
                <div class="card-header">
                    <h3 class="card-title">Nome</h3>
                </div>
                <!-- /.card-header -->
                <div class="card-body">
                    <div class="row">
                        @for (int i = 0; i < ViewBag.Languages.Count; i++)
                        {
                            int languageId = ViewBag.Languages[i].Id;
                            var currentTranslation = Model?.Translations?.FirstOrDefault(x => x.LanguageId == languageId);
                            <input type="hidden" name="Translations[@i].LanguageId" value="@languageId" />
                            <div class="col-md-4">
                                <div class="form-group form-group-label-on-top">
                                    <label for="Translations[@i].Name">Nome (@ViewBag.Languages[i].Name)</label>
                                    <input name="Translations[@i].Name" class="form-control form-control-sm" value="@(currentTranslation?.Name ?? "")" />
                                    <input type="hidden" name="Translations[@i].LanguageId" value="@languageId" />
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <!-- /.card-body -->
            </div>
            <!-- /.card -->
        </div>
        <div class="col-md-12">
            <div class="card card-success card-outline">
                <div class="card-header">
                    <h3 class="card-title">Horário</h3>
                </div>
                <!-- /.card-header -->
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group form-group-label-on-top">
                                <label for="MinimumAnticipationMinutes">Antecedência mínima da reserva (minutos)</label>
                                <input asp-for="MinimumAnticipationMinutes" class="form-control form-control-sm" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <div class="form-check">
                                    <input type="checkbox" class="form-check-input checkbox-is-closed" asp-for="IsAlwaysAvailableForPickupAndReturn" />
                                    <label asp-for="IsAlwaysAvailableForPickupAndReturn" class="form-check-label">Sempre disponível para recolha/devolução</label>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        @for (int i = 0; i < Model.DayOfWeekSchedules.Count; i++)
                        {
                            <div class="col-md-2 col-md-week">
                                <input type="hidden" asp-for="@Model.DayOfWeekSchedules[i].PickupReturnLocationId" />
                                <input type="hidden" asp-for="@Model.DayOfWeekSchedules[i].DayOfWeek" />
                                <div class="form-group form-group-label-on-top">
                                    <label for="@Model.DayOfWeekSchedules[i].OpeningTime">Dia</label>
                                    <input type="text" readonly class="form-control form-control-sm" value="@(dCore.Helpers.Enum.GetDescription(Model.DayOfWeekSchedules[i].DayOfWeek))" />
                                    <label for="@Model.DayOfWeekSchedules[i].OpeningTime">Abertura</label>
                                    <input type="time" class="form-control form-control-sm input-@i" asp-for="@Model.DayOfWeekSchedules[i].OpeningTime" />
                                    <label for="@Model.DayOfWeekSchedules[i].ClosingTime">Fecho</label>
                                    <input type="time" class="form-control form-control-sm input-@i" asp-for="@Model.DayOfWeekSchedules[i].ClosingTime" />
                                    <label for="@Model.DayOfWeekSchedules[i].LunchBreakStartTime">Início de Almoço</label>
                                    <input type="time" class="form-control form-control-sm input-@i" asp-for="@Model.DayOfWeekSchedules[i].LunchBreakStartTime" />
                                    <label for="@Model.DayOfWeekSchedules[i].LunchBreakEndTime">Fim de Almoço</label>
                                    <input type="time" class="form-control form-control-sm input-@i" asp-for="@Model.DayOfWeekSchedules[i].LunchBreakEndTime" />
                                </div>
                                <div class="form-group">
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input checkbox-is-closed" data-index="@i" asp-for="@Model.DayOfWeekSchedules[i].IsClosed" />
                                        <label asp-for="@Model.DayOfWeekSchedules[i].IsClosed" class="form-check-label">Encerrado</label>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <!-- /.card-body -->
            </div>
            <!-- /.card -->
        </div>
    </div>
    <div class="row mb-2">
        <div class="col-sm-12">
            <button type="submit" class="btn btn-outline-success btn-sm float-right ml-2"><i class="far fa-save"></i> Gravar</button>
            <a asp-controller="PickupReturnLocations" asp-action="Index" class="btn btn-outline-info btn-sm float-right ml-2"><i class="fas fa-undo-alt"></i> Voltar</a>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        $(function () {
            SetActiveMenu('menu-pickup-return-locations', 'menu-renting');

            $('.checkbox-is-closed').change(function () {
                DisableInputsWhenIsClosed(this)
            });

            $('.checkbox-is-closed').each(function () {
                DisableInputsWhenIsClosed(this)
            });

            function DisableInputsWhenIsClosed(element) {
                var index = $(element).data('index');
                if (element.checked) {
                    $(".input-" + index).prop('disabled', true);
                    $(".input-" + index).val('');
                }
                else {
                    $(".input-" + index).prop('disabled', false);
                }
            }
        });
    </script>
}