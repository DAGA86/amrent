@model AMRent.Data.Models.Database.Season

@{
    ViewData["Title"] = "Editar Data de Temporada";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
    <li class="breadcrumb-item active"><a asp-controller="Seasons" asp-action="Index">Datas de Temporada</a></li>
}

<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />
    <div class="row">
        <div class="card card-danger callout callout-danger">
            <div class="text-danger"><strong>ATENÇÃO:</strong> Ao editar uma data de temporada, todos os preços a que esta esteja associada serão afectados pela alteração. Se o objectivo é criar uma nova data de temporada, deverá fazê-lo <a asp-controller="Seasons" asp-action="Create">AQUI</a></div>
        </div>
        @if (ViewData.ModelState.ErrorCount > 0)
        {
            <div class="card card-danger callout callout-danger">
                <div asp-validation-summary="All" class="text-danger"></div>
            </div>
        }
        <div class="col-md-12">
            <div class="card card-success card-outline">
                <div class="card-header">
                    <h3 class="card-title">Geral</h3>
                </div>
                <!-- /.card-header -->
                <div class="card-body">
                    <div class="row">
                        <div class="col-sm-4">
                            <div class="form-group form-group-label-on-top">
                                <label for="SeasonCategoryId">Tipo de Temporada</label>
                                <select asp-for="SeasonCategoryId" class="form-control form-control-sm" asp-items="ViewBag.Categories">
                                    <option disabled selected></option>
                                </select>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="form-group form-group-label-on-top">
                                <label for="StartDateUtc">Data de começo</label>
                                <input name="StartDateUtc" type="text" value="@(Model.StartDateUtc != null ? Model.StartDateUtc.ToString("yyyy-MM-dd") : "")" class="form-control form-control-sm" data-inputmask-alias="datetime" data-inputmask-inputformat="yyyy-mm-dd" date-mask>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="form-group form-group-label-on-top">
                                <label for="EndDateUtc">Data de fim</label>
                                <input name="EndDateUtc" type="text" value="@(Model.EndDateUtc != null ? Model.EndDateUtc.ToString("yyyy-MM-dd") : "")" class="form-control form-control-sm" data-inputmask-alias="datetime" data-inputmask-inputformat="yyyy-mm-dd" date-mask>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- /.card-body -->
            </div>
            <!-- /.card -->
        </div>
    </div>
    <div class="row mb-2">
        <div class="col-sm-12">
            <button type="submit" class="btn btn-outline-success btn-sm float-right ml-2"><i class="far fa-save"></i> Gravar</button>
            <a asp-controller="Seasons" asp-action="Index" class="btn btn-outline-info btn-sm float-right ml-2"><i class="fas fa-undo-alt"></i> Voltar</a>
        </div>
    </div>
    <div class="row mb-2">
        @if (Model.Prices.Any())
        {
            <div class="col-md-12">
                <div class="card card-success card-outline">
                    <div class="card-header">
                        <h3 class="card-title">Preços associados</h3>
                    </div>
                    <!-- /.card-header -->
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-12">
                                <table class="table table-striped">
                                    <thead>
                                        <tr>
                                            <th>Segmento</th>
                                            <th>Dias</th>
                                            <th>Valor</th>
                                            <th>Acções</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                    @foreach (var priceItem in Model.Prices.OrderBy(x => x.CarSegment.Code).ThenBy(x => x.Days))
                                    {
                                            <tr>
                                                <td>@priceItem.CarSegment.Code</td>
                                                <td>@priceItem.Days</td>
                                                <td>@priceItem.Value</td>
                                                <td><a class="btn btn-info btn-xs btn-xs-square" href="/Prices/Edit/@priceItem.Id"><i class="fas fa-edit"></i></a></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
    <div class="row mb-2">
        @if (Model.Changes.Any())
        {
            <div class="col-md-12">
                <div class="card card-success card-outline">
                    <div class="card-header">
                        <h3 class="card-title">Histórico</h3>
                    </div>
                    <!-- /.card-header -->
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-12">
                                <table class="table table-striped">
                                    <thead>
                                        <tr>
                                            <th>Campo</th>
                                            <th>Valor Anterior</th>
                                            <th>Valor Novo</th>
                                            <th>Data</th>
                                            <th>Utilizador</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var changeItem in Model.Changes.OrderByDescending(x => x.ChangeDateTime).ThenBy(x => x.FieldName))
                                        {
                                            <tr>
                                                <td>@changeItem.FieldName</td>
                                                <td>@changeItem.OldValue</td>
                                                <td>@changeItem.NewValue</td>
                                                <td>@changeItem.ChangeDateTime</td>
                                                <td>@changeItem.User.Username</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</form>

@section Scripts {
    <script>
        $(function () {
            SetActiveMenu('menu-seasons', 'menu-renting');
        });
    </script>
}