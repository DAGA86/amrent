@model dCore.Identity.Models.UserViewModel
@{
    ViewData["Title"] = "Home Page";
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<div class="login-box">
    <!-- /.login-logo -->
    <div class="card card-outline card-success" style="border-top-width: 8px;">
        <div class="card-header text-center">
            <img src="~/img/logo.png" alt="AMC Logo" class="brand-image w-100">
        </div>
        <div class="card-body">
            @*<p class="login-box-msg">Login</p>*@
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <form id="account" method="post">
                <div class="input-group mb-3">
                    <input asp-for="Username" type="text" class="form-control" placeholder="Nome de utilizador" autocomplete="username" aria-required="true">
                    <div class="input-group-append">
                        <div class="input-group-text">
                            <span class="fas fa-user"></span>
                        </div>
                    </div>
                </div>
                <span asp-validation-for="Username" class="text-danger"></span>
                <div class="input-group mb-3">
                    <input asp-for="Password" type="password" class="form-control" placeholder="Palavra passe" autocomplete="current-password" aria-required="true">
                    <div class="input-group-append">
                        <div class="input-group-text">
                            <span class="fas fa-lock"></span>
                        </div>
                    </div>
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
                <div class="row">
                    <div class="col-8">
                        @*<div class="icheck-primary">
                            <input type="checkbox" asp-for="RememberMe">
                            <label asp-for="RememberMe">
                                Manter sessão iniciada
                            </label>
                        </div>*@
                    </div>
                    <!-- /.col -->
                    <div class="col-4">
                        <button type="submit" class="btn btn-success btn-block">Entrar</button>
                    </div>
                    <!-- /.col -->
                </div>
            </form>
        </div>
        <!-- /.card-body -->
    </div>
    <!-- /.card -->
</div>
<!-- /.login-box -->