@inject dCore.MultiLanguage.Providers.TranslationProvider TranslationProvider
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@model About
@{
    int languageId = HttpContextAccessor.HttpContext.Session.GetInt32("SelectedLanguage") ?? (int)AMRent.Data.Enums.Languages.Portuguese;
	ViewData["Title"] = TranslationProvider.GetTranslation(languageId, "Footer.SobreNos");
}

<!-- About -->
<section class="section about-sec">
	<div class="container">
		<div class="row align-items-center">
			<div class="col-lg-6" data-aos="fade-down">
				<div class="about-img">
					<div class="about-exp">
						<span>@Model.ImageSideText</span>
					</div>
					<div class="abt-img">
                        <img src="~/img/about.jpg" class="img-fluid" alt="About us">
					</div>
				</div>
			</div>
			<div class="col-lg-6" data-aos="fade-down">
				<div class="about-content">
					<h2>@Model.Title</h2>
					<p>@(Html.Raw(Model?.Text?.Replace("\n", "<br>")))</p>
				</div>
			</div>
		</div>
	</div>
</section>
<!-- /About -->

@section Scripts {
    <script>
        $(function () {
            SetActiveMenu('#menu-home');
        });
    </script>
}
