        function PaymentTypeSelect(paymentType) {
            $('.booking-form .form-group').hide();
            $('#payment-type-text-' + paymentType).show();
            $('.payment-method ul li a').removeClass('active');
            $('#payment-type-' + paymentType).addClass('active');
            $('#@(nameof(Model.PaymentType))').val(paymentType);
        }

        function GoToPayment() {
            Validate();
            if (valid) {
                if ($('#DriverLicenseDateInput').val() != '' && $('#DriverLicenseDateInput').val() != null) {
                    $('#DriverLicenseDate').val($('#DriverLicenseDateInput').val().split("-").reverse().join("-"));
                }
                if ($('#DriverLicenseExpireDateInput').val() != '' && $('#DriverLicenseExpireDateInput').val() != null) {
                    $('#DriverLicenseExpireDate').val($('#DriverLicenseExpireDateInput').val().split("-").reverse().join("-"));
                }
                if ($('#DriverLicenseDateInput').val() != '' && $('#DriverLicenseDateInput').val() != null) {
                    $('#DriverLicenseDate').val($('#DriverLicenseDateInput').val().split("-").reverse().join("-"));
                }
                @for (int i = 0; i < extraDriverQuantity; i++)
                {
                    @:if ($('[name="ExtraDrivers[@i].LicenseExpireDateInput"]').val() != '' && $('[name="ExtraDrivers[@i].LicenseExpireDateInput"]').val() != null) {
                        @:$('[name="ExtraDrivers[@i].LicenseExpireDate"]').val($('[name="ExtraDrivers[@i].LicenseExpireDateInput"]').val().split("-").reverse().join("-"));
                    @:}
                }
                $('#summary-div').removeClass('show').removeClass('active');
                $('#payment-div').addClass('show').addClass('active');
            }
        }

        function GoToSummary() {
            $('#payment-div').removeClass('show').removeClass('active');
            $('#summary-div').addClass('show').addClass('active');
        }

        function Validate() {
            valid = true;
            if ($('#DriverName').val() == '' || $('#DriverName').val() == null) {
                $('#DriverName').addClass("is-invalid");
                valid = false;
            } else {
                $('#DriverName').removeClass("is-invalid");
            }
            if ($('#DriverBirthDateInput').val() == '' || $('#DriverBirthDateInput').val() == null) {
                //$('#DriverBirthDateInput').addClass("is-invalid");
                //valid = false;
            } else {
                var selectedDate = $('#DriverBirthDateInput').val().split("-").reverse().join("-");
                if (!isAtLeast18YearsOld(selectedDate)) {
                    $('#DriverBirthDateInput').addClass("is-invalid");
                    valid = false;
                }
                else {
                    $('#DriverBirthDate').val(selectedDate);
                    $('#DriverBirthDateInput').removeClass("is-invalid");
                }
            }
            if ($('#DriverEmail').val() == '' || $('#DriverEmail').val() == null || !validateEmail($('#DriverEmail').val())) {
                $('#DriverEmail').addClass("is-invalid");
                valid = false;
            } else {
                $('#DriverEmail').removeClass("is-invalid");
            }
            if ($('#DriverTelephoneCountryId').val() == '' || $('#DriverTelephoneCountryId').val() == null) {
                $('[aria-labelledby="select2-DriverTelephoneCountryId-container"]').addClass("is-invalid");
                valid = false;
            } else {
                $('[aria-labelledby="select2-DriverTelephoneCountryId-container"]').removeClass("is-invalid");
            }
            if ($('#DriverTelephone').val() == '' || $('#DriverTelephone').val() == null || !validatePhoneNumber($('#DriverTelephone').val())) {
                $('#DriverTelephone').addClass("is-invalid");
                valid = false;
            } else {
