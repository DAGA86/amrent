@inject dCore.MultiLanguage.Providers.TranslationProvider TranslationProvider
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@using System.Globalization
@model BookingIndex
@{
    int languageId = HttpContextAccessor.HttpContext.Session.GetInt32("SelectedLanguage") ?? (int)AMRent.Data.Enums.Languages.Portuguese;
    ViewData["Title"] = TranslationProvider.GetTranslation(languageId, "Reserva.Titulo");

    int extraDriverQuantity = Model.Extras?.FirstOrDefault(x => x.Type == AMRent.Data.Enums.ExtraTypes.AdditionalDriver)?.Quantity ?? 0;
    while (Model.ExtraDrivers.Count < extraDriverQuantity)
    {
        Model.ExtraDrivers.Add(new ExtraDriver());
    }

    decimal segmentCost = Model.RentValue
                          + Model.PickupValue
                          + Model.ReturnValue;

    decimal totalCost = segmentCost
                    + Model.Insurances.FirstOrDefault().Prices.FirstOrDefault().Value
                    + Model.Extras.Sum(x => x.Cost)
                    + Model.PickupReturnTemporaryTaxes.Sum(x => x.Cost);
}

<section class="booking-section">
    <form asp-action="Confirm" method="post" id="booking-index-form">
        <input type="hidden" asp-for="CampaignId" />
        <input type="hidden" asp-for="VoucherId" />
        <input type="hidden" asp-for="VoucherCode" />
        <div class="container">
            <!-- Heading title-->
            <div class="section-heading" data-aos="fade-down">
                <h2>@ViewData["Title"]</h2>
            </div>
            <div class="tab-content">
                <div class="tab-pane fade show active" id="summary-div">
                    <div class="booking-details">
                        <div class="booking-title">
                            <h3>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.Titulo"))</h3>
                        </div>
                        <div class="booking-info">
                            <div class="row">
                                <div class="col-md-4 col-sm-6 pickup-address">
                                    <h5>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.Recolha"))</h5>
                                    <p>@Model.PickupLocationName</p>
                                    <span>@Model.PickupDateTime.ToString("dd/MM/yyyy", CultureInfo.InvariantCulture) @(Model.PickupDateTime.ToString("HH:mm"))</span>
                                </div>
                                <div class="col-md-4 col-sm-6 drop-address">
                                    <h5>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.Devolucao"))</h5>
                                    <p>@Model.ReturnLocationName</p>
                                    <span>@Model.ReturnDateTime.ToString("dd/MM/yyyy", CultureInfo.InvariantCulture) @(Model.ReturnDateTime.ToString("hh\\:mm"))</span>
                                </div>
                                <div class="col-md-4 col-sm-6 drop-address">
                                    <h5>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.Segmento"))</h5>
                                    <p>@Model.SegmentName @(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.Segmento.OuSimilar"))</p>
                                    <span>@Model.Days @(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.Segmento.Dias")): @(segmentCost)€</span>
                                </div>
                            </div>
                            <div class="row mt-3">
                                <div class="col-md-4 col-sm-6 pickup-address">
                                    <h5>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.Extras"))</h5>
                                    @foreach (AMRent.Website.Models.SelectedExtra extra in Model.Extras)
                                    {
                                        <p>@(extra.Name): @(extra.Cost)€</p>
                                    }
                                    @foreach (var pickupReturnTemporaryTax in Model.PickupReturnTemporaryTaxes)
                                    {
                                        <p>@(pickupReturnTemporaryTax.Name) (x @(pickupReturnTemporaryTax.Quantity)): @(pickupReturnTemporaryTax.UnitValue)€</p>
                                    }
                                </div>
                                <div class="col-md-4 col-sm-6 drop-address">
                                    <h5>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.Seguro"))</h5>
                                    <p>@Model.Insurances?.FirstOrDefault()?.InsuranceLevel?.Translations?.FirstOrDefault()?.Name: @(Model.Insurances?.FirstOrDefault()?.Prices.FirstOrDefault().Value)€</p>
                                    <span>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.Seguro.Franquia")) @(Model.Insurances.FirstOrDefault().Excess)€</span>
                                </div>
                                @if (Model.CampaignId.HasValue || Model.VoucherId.HasValue)
                                {
                                    <div class="col-md-4 col-sm-6 booking-amount">
                                        <h5>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.Total"))</h5>
                                        <h6><span><s>@(totalCost)€</s></span></h6>
                                        <h6><span>@Model.CampaignVoucherName : @(Model.TotalValue)€</span></h6>
                                    </div>
                                }
                                else
                                {
                                    <div class="col-md-4 col-sm-6 booking-amount">
                                        <h5>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.Total"))</h5>
                                        <h6><span>@(totalCost)€ </span></h6>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="booking-form">
                            <div class="booking-title">
                                <h5>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosCondutor.Titulo"))</h5>
                            </div>
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="form-group">
                                        <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosCondutor.Nome")) <span class="text-danger">*</span></label>
                                        <input asp-for="DriverName" type="text" class="form-control">
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosCondutor.DataNascimento")) <span class="text-danger">*</span></label>
                                        <div style="position: relative;">
                                            <input id="DriverBirthDateInput" type="text" value="@(Model.DriverBirthDate.ToString("dd-MM-yyyy"))" class="form-control datetimepicker">
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-8">
                                    <div class="form-group">
                                        <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosCondutor.Email")) <span class="text-danger">*</span></label>
                                        <input asp-for="DriverEmail" type="email" class="form-control">
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosCondutor.PaisTelefone")) <span class="text-danger">*</span></label>
                                        <select asp-for="DriverTelephoneCountryId" class="select2 form-control" style="width: 100%;" asp-items="ViewBag.Countries">
                                            <option disabled selected></option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-8">
                                    <div class="form-group">
                                        <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosCondutor.Telefone")) <span class="text-danger">*</span></label>
                                        <input asp-for="DriverTelephone" type="tel" class="form-control">
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosCondutor.TipoIdentificacao"))</label>
                                        <select asp-for="DriverIdentityType" class="select2 form-control" style="width: 100%;" asp-items="ViewBag.IdentityTypes">
                                            <option disabled selected></option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosCondutor.PaisIdentificacao"))</label>
                                        <select asp-for="DriverIdentityCardCountryId" class="select2 form-control" style="width: 100%;" asp-items="ViewBag.Countries">
                                            <option disabled selected></option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-3 check-in-data">
                                    <div class="form-group">
                                        <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosCondutor.NumeroIdentificacao"))</label>
                                        <input asp-for="DriverIdentityCardNumber" type="text" class="form-control">
                                    </div>
                                </div>
                                <div class="col-md-3 check-in-data">
                                    <div class="form-group">
                                        <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosCondutor.NumeroContribuinte"))</label>
                                        <input asp-for="DriverVatNumber" type="text" class="form-control">
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosCondutor.PaisCartaConducao"))</label>
                                        <select asp-for="DriverLicenseCountryId" class="select2 form-control" style="width: 100%;" asp-items="ViewBag.Countries">
                                            <option disabled selected></option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-3 check-in-data">
                                    <div class="form-group">
                                        <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosCondutor.NumeroCartaConducao"))</label>
                                        <input asp-for="DriverLicenseNumber" type="text" class="form-control">
                                    </div>
                                </div>
                                <div class="col-md-3 check-in-data">
                                    <div class="form-group">
                                        <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosCondutor.DataEmissaoCartaConducao"))</label>
                                        <div style="position: relative;">
                                            <input id="DriverLicenseDateInput" value="@(Model.DriverLicenseDate.ToString("dd-MM-yyyy"))" type="text" class="form-control datetimepicker">
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3 check-in-data">
                                    <div class="form-group">
                                        <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosCondutor.DataValidadeCartaConducao"))</label>
                                        <div style="position: relative;">
                                            <input id="DriverLicenseExpireDateInput" value="@(Model.DriverLicenseExpireDate.ToString("dd-MM-yyyy"))" type="text" class="form-control datetimepicker">
                                        </div>
                                    </div>
                                </div>
                            </div>
                            @for (int i = 0; i < extraDriverQuantity; i++)
                            {
                                <input asp-for="ExtraDrivers[i].BirthDate" type="hidden" />
                                <input asp-for="ExtraDrivers[i].LicenseExpireDate" type="hidden" />
                                <input asp-for="ExtraDrivers[i].LicenseDate" type="hidden" />
                                <div class="booking-title">
                                    <h5>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosCondutoresExtra.Titulo"))@(extraDriverQuantity > 1 ? $" {i+1}" : "")</h5>
                                </div>
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosCondutoresExtra.Nome")) <span class="text-danger">*</span></label>
                                            <input asp-for="ExtraDrivers[i].Name" type="text" class="form-control">
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosCondutoresExtra.DataNascimento")) <span class="text-danger">*</span></label>
                                            <div style="position: relative;">
                                                <input name="ExtraDrivers[@i].BirthDateInput" id="ExtraDrivers[@i].BirthDateInput" type="text" class="form-control datetimepicker">
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="form-group">
                                            <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosCondutoresExtra.PaisCartaConducao"))</label>
                                            <select asp-for="ExtraDrivers[i].LicenseCountryId" class="select2 form-control" style="width: 100%;" asp-items="ViewBag.Countries">
                                                <option disabled selected></option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-3 check-in-data">
                                        <div class="form-group">
                                            <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosCondutoresExtra.NumeroCartaConducao"))</label>
                                            <input asp-for="ExtraDrivers[i].LicenseNumber" type="text" class="form-control">
                                        </div>
                                    </div>
                                    <div class="col-md-3 check-in-data">
                                        <div class="form-group">
                                            <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosCondutoresExtra.DataEmissaoCartaConducao"))</label>
                                            <div style="position: relative;">
                                                <input name="ExtraDrivers[@i].LicenseDateInput" id="ExtraDrivers[@i].LicenseDateInput" type="text" class="form-control datetimepicker">
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-3 check-in-data">
                                        <div class="form-group">
                                            <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosCondutoresExtra.DataValidadeCartaConducao"))</label>
                                            <div style="position: relative;">
                                                <input name="ExtraDrivers[@i].LicenseExpireDateInput" id="ExtraDrivers[@i].LicenseExpireDateInput" type="text" class="form-control datetimepicker">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                            <div class="booking-title">
                                <h5>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosFaturacao.Titulo"))</h5>
                            </div>
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="form-group">
                                        <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosFaturacao.Nome")) <span class="text-danger">*</span></label>
                                        <input asp-for="BillName" type="text" class="form-control">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosFaturacao.Email")) <span class="text-danger">*</span></label>
                                        <input asp-for="BillEmail" type="email" class="form-control">
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosFaturacao.PaisTelefone"))  <span class="text-danger">*</span></label>
                                        <select asp-for="BillTelephoneCountryId" class="select2 form-control" style="width: 100%;" asp-items="ViewBag.Countries">
                                            <option disabled selected></option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosFaturacao.Telefone"))  <span class="text-danger">*</span></label>
                                        <input asp-for="BillTelephone" type="text" class="form-control">
                                    </div>
                                </div>
                                <div class="col-md-6 check-in-data">
                                    <div class="form-group">
                                        <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosFaturacao.Morada"))</label>
                                        <input asp-for="BillAddress" type="text" class="form-control">
                                    </div>
                                </div>
                                <div class="col-md-2 check-in-data">
                                    <div class="form-group">
                                        <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosFaturacao.CodigoPostal"))</label>
                                        <input asp-for="BillPostalCode" type="text" class="form-control">
                                    </div>
                                </div>
                                <div class="col-md-4 check-in-data">
                                    <div class="form-group">
                                        <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosFaturacao.LocalidadePostal"))</label>
                                        <input asp-for="BillPostalLocation" type="text" class="form-control">
                                    </div>
                                </div>
                                <div class="col-md-6 check-in-data">
                                    <div class="form-group">
                                        <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosFaturacao.Pais")) <span class="text-danger">*</span></label>
                                        <select asp-for="BillCountryId" class="select2 form-control" style="width: 100%;" asp-items="ViewBag.Countries">
                                            <option disabled selected></option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-6 check-in-data">
                                    <div class="form-group">
                                        <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosFaturacao.NumeroContribuinte"))</label>
                                        <input asp-for="BillVatNumber" type="text" class="form-control">
                                    </div>
                                </div>
                            </div>
                            <div class="booking-title">
                                <h5>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosOutros.Titulo"))</h5>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosOutros.NumeroVoo"))</label>
                                        <input asp-for="FlightNumber" type="text" class="form-control">
                                    </div>
                                </div>
                                <div class="col-md-12">
                                    <div class="form-group">
                                        <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.DadosOutros.Comentarios"))</label>
                                        <textarea asp-for="Comments" rows="2" class="form-control"></textarea>
                                    </div>
                                </div>
                            </div>
                            <div class="booking-title">
                                <h5>@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.Consentimentos.Titulo"))</h5>
                            </div>
                            <div class="row">
                                @for (int i = 0; i < Model.DataProtectionConsents.Count; i++)
                                {
                                    <div class="col-md-12">
                                        <div class="form-group">
                                            <input type="hidden" asp-for="DataProtectionConsents[i].Id" />
                                            <label class="custom_check">
                                                <input type="checkbox" asp-for="DataProtectionConsents[i].HasConsent" class="rememberme">
                                                <span class="checkmark" name="DataProtectionConsents[@i].HasConsentSpan"></span>
                                                @(Model.DataProtectionConsents[i].Text)
                                            </label>
                                        </div>
                                    </div>
                                }
                            </div>
                            <div class="payment-btn">
                                <a class="btn btn-primary submit-review" onclick="javascript:GoToPayment();" href="#">@(TranslationProvider.GetTranslation(languageId, "Reserva.Detalhe.Botao"))<i class="fa-solid fa-arrow-right ms-2"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="tab-pane fade" id="payment-div">
                    <div class="booking-details payment-details">
                        <div class="booking-title">
                            <h3>@(TranslationProvider.GetTranslation(languageId, "Reserva.Pagamento.Titulo"))</h3>
                        </div>
                        <div class="booking-info">
                            <div class="booking-amount">
                                <h5>@(TranslationProvider.GetTranslation(languageId, "Reserva.Pagamento.Valor.Titulo"))</h5>
                                @if (Model.CampaignId.HasValue || Model.VoucherId.HasValue)
                                {
                                    <h6><s><span>@(totalCost)€ </span></s><i class="feather-info"></i></h6>
                                    <h6>
                                        <span>
                                            @Model.CampaignVoucherName : @(Model.TotalValue)€
                                        </span><i class="feather-info"></i>
                                    </h6>
                                }
                                else
                                {
                                    <h6><span>@(totalCost)€ </span><i class="feather-info"></i></h6>
                                }
                                
                            </div>
                        </div>
                        <div class="payment-method">
                            <h4 class="text-danger">@(TranslationProvider.GetTranslation(languageId, "Reserva.Pagamento.EscolhaMetodo.Titulo"))</h4>
                            <ul>
                                <li><a id="payment-type-@(AMRent.Data.Enums.PaymentTypes.BankTransfer)" class="active" onclick="javascript: PaymentTypeSelect('@(AMRent.Data.Enums.PaymentTypes.BankTransfer)'); return false;"><img src="~/img/icons/payment-iban.png" alt=""></a></li>
                                <li><a id="payment-type-@(AMRent.Data.Enums.PaymentTypes.MBReference)" onclick="javascript: PaymentTypeSelect('@(AMRent.Data.Enums.PaymentTypes.MBReference)'); return false;"><img src="~/img/icons/payment-multibanco.svg" alt=""></a></li>
                                <li><a id="payment-type-@(AMRent.Data.Enums.PaymentTypes.MBWay)" onclick="javascript: PaymentTypeSelect('@(AMRent.Data.Enums.PaymentTypes.MBWay)'); return false;"><img src="~/img/icons/payment-mbway.svg" alt=""></a></li>
                                <li><a id="payment-type-@(AMRent.Data.Enums.PaymentTypes.CreditCard)" onclick="javascript: PaymentTypeSelect('@(AMRent.Data.Enums.PaymentTypes.CreditCard)'); return false;"><img src="~/img/icons/payment-credit-card.svg" alt=""></a></li>
                                @* <li><a id="payment-type-@(AMRent.Data.Enums.PaymentTypes.Paypal)" onclick="javascript: PaymentTypeSelect('@(AMRent.Data.Enums.PaymentTypes.Paypal)'); return false;"><img src="~/img/icons/payment-paypal.svg" alt=""></a></li> *@
                            </ul>
                            <div class="booking-form">
                                <div>
                                    @* <div class="booking-title">
                                    <h5>Enter Below details</h5>
                                    </div> *@
                                    <div class="row">
                                        <div class="col-lg-12">
                                            <div class="form-group" id="payment-type-text-@(AMRent.Data.Enums.PaymentTypes.BankTransfer)">
                                                <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Pagamento.TransferenciaBancaria.Texto")) <span class="text-danger">*</span></label>
                                            </div>
                                            <div class="form-group" id="payment-type-text-@(AMRent.Data.Enums.PaymentTypes.MBReference)" style="display: none;">
                                                <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Pagamento.ReferenciaMultibanco.Texto")) <span class="text-danger">*</span></label>
                                            </div>
                                            <div class="form-group" id="payment-type-text-@(AMRent.Data.Enums.PaymentTypes.MBWay)" style="display: none;">
                                                <label for="MbWayNumber">@(TranslationProvider.GetTranslation(languageId, "Reserva.Pagamento.MbWay.Texto")) <span class="text-danger">*</span></label>
                                                <input asp-for="MbWayNumber" class="form-control">
                                            </div>
                                            <div class="form-group" id="payment-type-text-@(AMRent.Data.Enums.PaymentTypes.CreditCard)" style="display: none;">
                                                <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Pagamento.CartaoCredito.Texto")) <span class="text-danger">*</span></label>
                                            </div>
                                            @* <div class="form-group" id="payment-type-text-@(AMRent.Data.Enums.PaymentTypes.Paypal)" style="display: none;">
                                                <label>@(TranslationProvider.GetTranslation(languageId, "Reserva.Pagamento.Paypal.Texto")) <span class="text-danger">*</span></label>
                                            </div> *@
                                        </div>
                                    </div>
                                </div>
                                <div class="payment-btn">
                                    <button class="btn btn-primary submit-review w-100" type="button" onclick="javascript:Book();">@(TranslationProvider.GetTranslation(languageId, "Reserva.Pagamento.Botao"))</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- /Booking  -->
        </div>
        <input asp-for="SegmentId" type="hidden" />
        <input asp-for="PickupLocationId" type="hidden" />
        <input asp-for="ReturnLocationId" type="hidden" />
        <input asp-for="PickupDateTime" type="hidden" />
        <input asp-for="ReturnDateTime" type="hidden" />
        <input asp-for="SelectedInsuranceLevelId" type="hidden" />
        <input asp-for="DriverBirthDate" type="hidden" />
        <input asp-for="DriverLicenseDate" type="hidden" />
        <input asp-for="DriverLicenseExpireDate" type="hidden" />
        <input asp-for="RentValue" type="hidden" />
        <input asp-for="PickupValue" type="hidden" />
        <input asp-for="ReturnValue" type="hidden" />
        <input asp-for="PaymentType" type="hidden" />
        @for (int i = 0; i < Model.Extras.Count; i++)
        {
            <input asp-for="Extras[i].Id" type="hidden" />
            <input asp-for="Extras[i].Quantity" type="hidden" />
            <input asp-for="Extras[i].Cost" type="hidden" />
            <input asp-for="Extras[i].DailyValue" type="hidden" />
        }
    </form>
</section>

