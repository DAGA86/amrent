@inject dCore.MultiLanguage.Providers.TranslationProvider TranslationProvider
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@model AMRent.Data.Models.Database.BlogArticle
@{
    int languageId = HttpContextAccessor.HttpContext.Session.GetInt32("SelectedLanguage") ?? (int)AMRent.Data.Enums.Languages.Portuguese;
    ViewData["Title"] = $"{TranslationProvider.GetTranslation(languageId, "Menu.Blog")} - ";
}

<!-- Banner Section -->
<div class="blogbanner" style="background-image: url(/img/blog/@(Model.Id)_top.jpg);">
    <div class="blogbanner-content">
        @*<span class="blog-hint">Health</span>*@
        <h1>@(Model.Translations?.FirstOrDefault()?.Title)</h1>
        <ul class="entry-meta meta-item justify-content-center">
            <li>
            </li>
            <li class="date-icon"><i class="fa-solid fa-calendar-days"></i> @(Model.CreateDate.ToString("dd/MM/yyyy"))</li>
        </ul>
    </div>
</div>
<!-- /Banner Section -->
<!-- Blog Grid-->
<div class="blog-section">
    <div class="container">
        <div class="blog-description">
            <p>@(Html.Raw(Model.Translations?.FirstOrDefault()?.Text.Replace("\n", "<br>")))</p>
        </div>
        @if (!string.IsNullOrEmpty(Model.ImagePath) || !string.IsNullOrEmpty(Model.Translations?.FirstOrDefault()?.YoutubeURL))
        {
            <div class="row">
                @if (!string.IsNullOrEmpty(Model.ImagePath))
                {
                    <div class="col-lg-6 col-md-6">
                        <div class="bloginner-img">
                            <img src="~/img/blog/@(Model.Id).jpg" class="img-fluid" alt="">
                        </div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.Translations?.FirstOrDefault()?.YoutubeURL))
                {
                    <div class="col-lg-6 col-md-6">
                        <div class="bloginner-img">
                            <div class="short-video" style="aspect-ratio: 3 / 2;">
                                <iframe src="@(Model.Translations?.FirstOrDefault()?.YoutubeURL)" width="100%" height="100%"></iframe>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        <div class="share-postsection">
            <div class="row">
                <div class="col-lg-4">
                    @*<div class="sharelink d-flex align-items-center">
                    <a href="javasvript:void();" class="share-img"><i class="feather-share-2"></i></a>
                    <a href="javasvript:void();" class="share-text">Share</a>
                    </div>*@
                </div>
                <div class="col-lg-8">
                    <div class="tag-list">
                        <ul class="tags">
                            @{
                                if (!string.IsNullOrEmpty(Model.Translations?.FirstOrDefault()?.Tags))
                                {
                                    foreach (string tag in Model.Translations?.FirstOrDefault()?.Tags.Split(','))
                                    {
                                        <li>@tag </li>
                                    }
                                }
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>@*
