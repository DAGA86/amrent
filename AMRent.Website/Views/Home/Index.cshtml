<!-- Rental deals -->
<section class="section popular-services">
    <div class="container">
        <!-- Heading title-->
        <div class="section-heading" data-aos="fade-down">
            <h2>@TranslationProvider.GetTranslation(languageId, "Home.MaisAlugados.Titulo")</h2>
            <p>@TranslationProvider.GetTranslation(languageId, "Home.MaisAlugados.Subtitulo")</p>
        </div>
        <!-- /Heading title -->
        <div class="row">
            <div class="popular-slider-group">
                <div class="owl-carousel rental-deal-slider owl-theme">
                    @foreach (CarSegment carSegment in Model.MostRented)
                    {
                        <!-- owl carousel item -->
                        <div class="rental-car-item">
                            <div class="listing-item mb-0">
                                <div class="listing-img">
                                    <a asp-controller="Segment" asp-action="Detail" asp-route-segmentId="@carSegment.Id">
                                        <img src="~/img/segments/@(carSegment.Id)_grid.jpg" asp-append-version="true" class="img-fluid" alt="@(carSegment.Translations?.FirstOrDefault()?.Name)">
                                    </a>
                                </div>
                                <div class="listing-content">
                                    <div class="listing-features">
                                        <div class="fav-item-rental">
                                            <span class="featured-text">@(carSegment.Prices?.FirstOrDefault()?.Value) € / @TranslationProvider.GetTranslation(languageId, "Pesquisa.Segmento.Preco.Dia")</span>
                                        </div>
                                        <h3 class="listing-title">
                                            <a asp-controller="Segment" asp-action="Detail" asp-route-segmentId="@carSegment.Id">@(carSegment.Translations?.FirstOrDefault()?.Name)</a>
                                        </h3>
                                    </div>
                                    <div class="listing-button">
                                        <a asp-controller="Segment" asp-action="Detail" asp-route-segmentId="@carSegment.Id" class="btn btn-order"><span><i class="feather-calendar me-2"></i></span>@TranslationProvider.GetTranslation(languageId, "Pesquisa.Segmento.Botao")</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- /owl carousel item -->
                    }
                </div>
            </div>
        </div>
        <!-- View More -->
        <div class="view-all text-center" data-aos="fade-down">
            <a asp-controller="Search" asp-action="Index" class="btn btn-view d-inline-flex align-items-center">@TranslationProvider.GetTranslation(languageId, "Home.MaisAlugados.Botao") <span><i class="feather-arrow-right ms-2"></i></span></a>
        </div>
        <!-- View More -->
    </div>
</section>
<!-- /Rental deals -->
