@model HomeIndex
@using Microsoft.AspNetCore.Mvc.TagHelpers
@using AMRent.Data.Models.Database
@inject dCore.MultiLanguage.Providers.TranslationProvider TranslationProvider
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    int languageId = HttpContextAccessor.HttpContext.Session.GetInt32("SelectedLanguage") ?? (int)AMRent.Data.Enums.Languages.Portuguese;
    ViewData["Title"] = TranslationProvider.GetTranslation(languageId, "Menu.Home");
    // Todo: verificar ALT das imagens
}

<!-- Banner -->

<div id="home-carousel" class="carousel slide" data-bs-ride="carousel">
    <div class="carousel-inner">
        @for (int i = 0; i < Model.HomeBanners.Count; i++)
        {
            <div class="carousel-item @(i == 0 ? "active" : "")">
                <a href="@Model.HomeBanners[i].Translations?.FirstOrDefault()?.URL">
                    <img src="~/img/homebanners/@($"{Model.HomeBanners[i].Id}_{ViewBag.SelectedLanguageObject.Code}_{ViewBag.SelectedLanguageObject.CountryCode}").jpg" class="d-block w-100" />
                </a>
            </div>
        }
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#home-carousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#home-carousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
    </button>
</div>
<!-- /Banner -->
<!-- Search -->
<div class="section-search">
    <div class="container">
        <div class="search-box-banner">
            <form id="home-search-form" asp-controller="Search" asp-action="Index" method="post">
                <div class="row">
                    <div class="col-md-6 col-sm-12 m-0">
                        <div class="row">
                            <div class="col-12 p-0">
                                <div class="form-group">
                                    <label>@TranslationProvider.GetTranslation(languageId, "Home.Pesquisa.Recolha")</label>
                                </div>
                            </div>
                            <div class="col-xxl-6 col-lg-12 p-0">
                                <div class="form-group">
                                    <div class="group-img">
                                        <select asp-for="PickupLocationId" class="select2 form-control" style="width: 100%;" asp-items="ViewBag.Locations"></select>
                                        <span><i class="feather-map-pin"></i></span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-xxl-3 col-sm-7 p-0">
                                <div class="form-group date-widget">
                                    <div class="group-img">
                                        <input type="hidden" asp-for="PickupDateTime" id="PickupDateTime" name="PickupDateTime" />
                                        <input id="PickupDate" type="text" class="form-control datetimepicker" value="@Model.PickupDateTime.ToString("dd-MM-yyyy")" placeholder="@TranslationProvider.GetTranslation(languageId, "Placeholder.Data")">
                                        <span><i class="feather-calendar"></i></span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-xxl-3 col-sm-5 p-0">
                                <div class="form-group time-widget">
                                    <div class="group-img">
                                        <input id="PickupTime" name="PickupTime" type="text" class="form-control timepicker" value="@Model.PickupDateTime.TimeOfDay" placeholder="@TranslationProvider.GetTranslation(languageId, "Placeholder.Hora")">
                                        <span><i class="feather-clock"></i></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-sm-12 m-0 mt-sm-2 mt-md-0">
                        <div class="row">
                            <div class="col-12 mt-xxl-0 p-0">
                                <div class="form-group">
                                    <label>@TranslationProvider.GetTranslation(languageId, "Home.Pesquisa.Devolucao")</label>
                                </div>
                            </div>
                            <div class="col-xxl-6 col-lg-12 p-0">
                                <div class="form-group">
                                    <div class="group-img">
                                        <select asp-for="ReturnLocationId" class="select2 form-control" style="width: 100%;" asp-items="ViewBag.Locations"></select>
                                        <span><i class="feather-map-pin"></i></span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-xxl-3 col-sm-7 p-0">
                                <div class="form-group date-widget">
                                    <div class="group-img">
                                        <input type="hidden" asp-for="ReturnDateTime" />
                                        <input id="ReturnDate" type="text" class="form-control datetimepicker" value="@Model.ReturnDateTime.ToString(" dd-MM-yyyy")" placeholder="@TranslationProvider.GetTranslation(languageId, "Placeholder.Data")">
                                        <span><i class="feather-calendar"></i></span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-xxl-3 col-sm-5 p-0">
                                <div class="form-group time-widget">
                                    <div class="group-img">
                                        <input id="ReturnTime" name="ReturnTime" type="text" class="form-control timepicker" value="@Model.ReturnDateTime.TimeOfDay" placeholder="@TranslationProvider.GetTranslation(languageId, "Placeholder.Hora")">
                                        <span><i class="feather-clock"></i></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12 col-sm-3 mt-3 p-0" style="margin-left: auto;">
                        <div class="form-group form-group-search-button">
                            <div class="search-btn">
                                <button class="btn search-button" type="button" onclick="javascript:Search();"> <i class="fa fa-search" aria-hidden="true"></i>@TranslationProvider.GetTranslation(languageId, "Home.Pesquisa.Botao")</button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- /Search -->
@if (Model.Campaigns.Any())
{
    <div class="modal fade" id="campaignModal" tabindex="-1" aria-labelledby="campaignModalLabel">
        <div class="modal-dialog modal-dialog-centered" style="width:80%; max-width: 80%; height:80%; max-height: 80%;">
            <img style="width: 100%; max-height: 100%" src="/img/campaigns/@($"{Model.Campaigns.First().Id}_popup_{ViewBag.SelectedLanguageObject.Code}_{ViewBag.SelectedLanguageObject.CountryCode}").jpg" />
        </div>
    </div>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
          var myModal = new bootstrap.Modal(document.getElementById('campaignModal'));
          myModal.show();
        });
    </script>
    <!-- Pricing Plan -->
    <section class="section pricing-section pricing-page pricing-section-bottom campaing-section">
        <div class="container">
            <!-- Heading title-->
            <div class="section-heading" data-aos="fade-down">
                <h2>@TranslationProvider.GetTranslation(languageId, "Home.Campanhas.Titulo")</h2>
                <p>@TranslationProvider.GetTranslation(languageId, "Home.Campanhas.Subtitulo")</p>
            </div>
            <!-- /Heading title -->
            <div class="row">
                @foreach (Campaign campaign in Model.Campaigns)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6 col-12" data-aos="fade-down">
                        <a asp-controller="Search" asp-action="Index" asp-route-filteredCampaignIds="@campaign.Id">
                            <div class="col-12 campaign-card" style="background-image: url('/img/campaigns/@($"{campaign.Id}_{ViewBag.SelectedLanguageObject.Code}_{ViewBag.SelectedLanguageObject.CountryCode}").jpg');"></div>
                        </a>
                    </div>
                }
            </div>

        </div>
    </section>
    <!-- /Pricing Plan -->
}

