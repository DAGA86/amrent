        <!-- Heading title-->
        <div class="section-heading" data-aos="fade-down">
            <h2>@TranslationProvider.GetTranslation(languageId, "Home.RazoesParaAlugarConnosco.Titulo")</h2>
            <p>@TranslationProvider.GetTranslation(languageId, "Home.RazoesParaAlugarConnosco.Subtitulo")</p>
        </div>
        <!-- /Heading title -->
        <div class="why-choose-group">
            <div class="row">
                @foreach (ReasonToChooseUs reasonToChooseUs in Model.ReasonsToChooseUs)
                {
                    <div class="col-lg-3 col-md-6 col-12 d-flex" data-aos="fade-down">
                        <div class="card flex-fill">
                            <div class="card-body">
                                <div class="choose-img choose-primary">
                                    <i class="@(reasonToChooseUs.FontAwesomeIconCode)"></i>
                                </div>
                                <div class="choose-content">
                                    <h4>@(reasonToChooseUs.Translations?.FirstOrDefault()?.Title)</h4>
                                    <p>@(reasonToChooseUs.Translations?.FirstOrDefault()?.Text)</p>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
<!-- /Why Choose Us -->
<!-- About us Testimonials -->
<section class="section about-testimonial testimonials-section">
    <div class="container">
        <!-- Heading title-->
        <div class="section-heading" data-aos="fade-down">
            <h2 class="title">@TranslationProvider.GetTranslation(languageId, "Home.Testemunhos.Titulo")</h2>
            <p>@TranslationProvider.GetTranslation(languageId, "Home.Testemunhos.Subtitulo")</p>
        </div>
        <!-- /Heading title -->
        <div class="owl-carousel about-testimonials testimonial-group mb-0 owl-theme">
            @foreach (Testimonial testimonial in Model.Testimonials)
            {
                <!-- Carousel Item -->
                <div class="testimonial-item d-flex">
                    <div class="card flex-fill">
                        <div class="card-body">
                            <div class="quotes-head">
                                <i class="fa-solid fa-quote-left"></i>
                            </div>
                            <div class="review-box">
                                <div class="review-details">
                                    <h6>@(testimonial.AuthorName)</h6>
                                    <div class="list-rating">
                                        <div class="list-rating-star">
                                            @for (int i = 0; i < testimonial.Score; i++)
                                            {
                                                <i class="fas fa-star filled"></i>
                                            }
                                        </div>
                                        <p><span>(@(testimonial.Score).0)</span></p>
                                    </div>
                                </div>
                            </div>
                            <p>@(testimonial.Translations?.FirstOrDefault()?.Text)</p>
                        </div>
                    </div>
                </div>
                <!-- /Carousel Item  -->
            }
        </div>
    </div>
</section>
<!-- About us Testimonials -->
@section Scripts {
    <script>
        function Search() {
            var valid = true;
            if ($('#PickupLocationId').val() == '' || $('#PickupLocationId').val() == null) {
                $('[aria-labelledby="select2-PickupLocationId-container"]').addClass("is-invalid");
                valid = false;
            } else {
                $('[aria-labelledby="select2-PickupLocationId-container"]').removeClass("is-invalid");
            }
            if ($('#PickupDate').val() == '' || $('#PickupDate').val() == null) {
                $('#PickupDate').addClass("is-invalid");
                valid = false;
            } else {
                $('#PickupDate').removeClass("is-invalid");
            }
            if ($('#PickupTime').val() == '' || $('#PickupTime').val() == null) {
                $('#PickupTime').addClass("is-invalid");
                valid = false;
            } else {
                $('#PickupTime').removeClass("is-invalid");
            }
            if ($('#ReturnLocationId').val() == '' || $('#ReturnLocationId').val() == null) {
                $('[aria-labelledby="select2-ReturnLocationId-container"]').addClass("is-invalid");
                valid = false;
            } else {
                $('[aria-labelledby="select2-ReturnLocationId-container"]').removeClass("is-invalid");
            }
            if ($('#ReturnDate').val() == '' || $('#ReturnDate').val() == null) {
                $('#ReturnDate').addClass("is-invalid");
                valid = false;
            } else {
                $('#ReturnDateInput').removeClass("is-invalid");
            }
            if ($('#ReturnTime').val() == '' || $('#ReturnTime').val() == null) {
                $('#ReturnTime').addClass("is-invalid");
                valid = false;
            } else {
                $('#ReturnTime').removeClass("is-invalid");
            }

            if (valid) {
                $('#PickupDateTime').val($('#PickupDate').val().split("-").reverse().join("-") + ' ' + $('#PickupTime').val())
                $('#ReturnDateTime').val($('#ReturnDate').val().split("-").reverse().join("-") + ' ' + $('#ReturnTime').val());
                $('#home-search-form').submit();
            }
        }
        $(function () {
            SetActiveMenu('#menu-home');
            $('.select2').select2();
        });

    </script>
}