                                                <input type="checkbox" class="gearboxCheckbox" data-id="@(carGearbox.Key)" @(Model.SelectedGearboxIds.Contains(carGearbox.Key) ? "checked='checked'" : "")>
                                                <span class="checkmark"></span> @(carGearbox.Value)
                                            </label>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- /Gearbox -->
                        <!-- Seats -->
                        <select asp-for="SelectedSeatNumbers" multiple="multiple" style="display:none;">
                            @foreach (int carSeat in Model.CarSeats)
                            {
                                <option value="@carSeat">@carSeat</option>
                            }
                        </select>
                        @{
                            bool showSeatsFilter = Model.SelectedSeatNumbers.Any();
                        }
                        <div class="accordion" id="seat-div">
                            <div class="card-header-new" id="headingFour">
                                <h6 class="filter-title">
                                    <a href="javascript:void(0);" class="w-100 @(showSeatsFilter ? "" : "collapsed")" data-bs-toggle="collapse" data-bs-target="#collapseFour" aria-expanded="@(showSeatsFilter ? "true" : "false")" aria-controls="collapseFour">
                                        @TranslationProvider.GetTranslation(languageId, "Pesquisa.Filtros.Lugares")
                                        <span class="float-end"><i class="fa-solid fa-chevron-down"></i></span>
                                    </a>
                                </h6>
                            </div>
                            <div id="collapseFour" class="collapse @(showSeatsFilter ? "show" : "")" aria-labelledby="headingFour" data-bs-parent="#accordionExample4">
                                <div class="card-body-chat">
                                    <div class="selectBox-cont">
                                        @foreach (int carSeat in Model.CarSeats.OrderBy(x => x))
                                        {
                                            <label class="custom_check w-100">
                                                <input type="checkbox" class="seatCheckbox" data-id="@(carSeat)" @(Model.SelectedSeatNumbers.Contains(carSeat) ? "checked='checked'" : "")>
                                                <span class="checkmark"></span> @(carSeat)
                                            </label>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- /Seats -->
                        <!-- Campaigns -->
                        @{
                            //TODO: voltar a mostrar quando activar campanhas
                            bool showCampaignsFilter = Model.SelectedCampaignIds.Any();
                        }
                        @*
                        <select asp-for="SelectedCampaignIds" multiple="multiple" style="display:none;">
                        @foreach (KeyValuePair<int, string?> campaign in Model.Campaigns.OrderBy(x => x.Value))
                        {
                        <option value="@campaign.Key">@campaign.Value</option>
                        }
                        </select>
                        <div class="accordion" id="campaign-div">
                        <div class="card-header-new" id="headingFive">
                        <h6 class="filter-title">
                        <a href="javascript:void(0);" class="w-100 @(showCampaignsFilter ? "" : "collapsed")" data-bs-toggle="collapse" data-bs-target="#collapseFive" aria-expanded="@(showCampaignsFilter ? "true" : "false")" aria-controls="collapseFive">
