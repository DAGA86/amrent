                                                                <p>@(Model.CarGearboxes[segment.CarGearboxId])</p>
                                                            </li>
                                                            <li>
                                                                <span><img src="~/img/icons/car-parts-03.svg" alt="Petrol"></span>
                                                                <p>@(Model.CarFuels[segment.CarFuelId])</p>
                                                            </li>
                                                            <li>
                                                                <span><img src="~/img/icons/car-parts-06.svg" alt="Persons"></span>
                                                                <p>@(segment.Seats)</p>
                                                            </li>
                                                        </ul>
                                                        <ul>
                                                            @if (segment.CarCategory.IsCommercial)
                                                            {
                                                                <li>
                                                                    <span><img src="~/img/icons/truck_length.svg" alt="Length"></span>
                                                                    <p>@((segment.LoadingSpaceLengthInMilimeters.HasValue ? ((double)segment.LoadingSpaceLengthInMilimeters / 1000) : 0).ToString("0.00")) m</p>
                                                                </li>
                                                                <li>
                                                                    <span><img src="~/img/icons/truck_width.svg" alt="Width"></span>
                                                                    <p>@((segment.LoadingSpaceWidthInMilimeters.HasValue ? ((double)segment.LoadingSpaceWidthInMilimeters / 1000) : 0).ToString("0.00")) m</p>
                                                                </li>
                                                                <li>
                                                                    <span><img src="~/img/icons/truck_height.svg" alt="Height"></span>
                                                                    <p>@((segment.LoadingSpaceHeightInMilimeters.HasValue ? ((double)segment.LoadingSpaceHeightInMilimeters / 1000) : 0).ToString("0.00")) m</p>
                                                                </li>
