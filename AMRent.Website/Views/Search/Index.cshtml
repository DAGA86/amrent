                        <span class="checkmark"></span> @(campaign.Value)
                        </label>
                        }
                        </div>
                        </div>
                        </div>
                        </div>*@
                        <!-- /Campaigns -->
                        <button type="button" onclick="javascript:ClearFilters();" class="d-inline-flex align-items-center justify-content-center btn w-100 btn-primary filter-btn">
                            <span><i class="feather-filter me-2"></i></span>@TranslationProvider.GetTranslation(languageId, "Pesquisa.Filtros.LimparFiltros")
                        </button>
