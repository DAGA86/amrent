                                    <a href="javascript:void(0);" class="w-100 @(showGearboxFilter ? "" : "collapsed")" data-bs-toggle="collapse" data-bs-target="#collapseThree" aria-expanded="@(showGearboxFilter ? "true" : "false")" aria-controls="collapseThree">
