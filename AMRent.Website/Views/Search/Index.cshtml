                                                    @TranslationProvider.GetTranslation(languageId, "Pesquisa.Segmento.Preco.Total"): @(Model.Prices[segment.Id])€
                                                </div>
                                            </div>
                                            <div class="listing-details-group">
                                                <ul>
                                                    <li>
                                                        <span><img src="~/img/icons/car-parts-01.svg" alt="Auto"></span>
                                                        <p>@(Model.CarGearboxes[segment.CarGearboxId])</p>
                                                    </li>
                                                    <li>
                                                        <span><img src="~/img/icons/car-parts-03.svg" alt="Petrol"></span>
                                                        <p>@(Model.CarFuels[segment.CarFuelId])</p>
