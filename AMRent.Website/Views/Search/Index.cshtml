                        <span class="float-end"><i class="fa-solid fa-chevron-down"></i></span>
                        </a>
                        </h6>
                        </div>
                        <div id="collapseFive" class="collapse @(showCampaignsFilter ? "show" : "")" aria-labelledby="headingFive" data-bs-parent="#accordionExample5">
                        <div class="card-body-chat">
