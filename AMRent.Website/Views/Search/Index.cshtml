                </div>
            }
        </div>
    </div>
</section>
@section Scripts
{
    <script>
        var viewType = '@(Model.ViewLayout)';

        function ChangeView(newViewType) {
            $('#ViewLayout').val(newViewType);
            Filter();
        }

        function ClearFilters() {
            $(':checkbox').prop('checked', false);
            Filter();
        }

        function Filter(anchor, clickedCheckbox) {
            $('#search-index-form').attr('action', '/Search');
            $('#Anchor').val(anchor);
            if (ValidateForm()) {
                Submit();
            } else if (clickedCheckbox != null) {
                $(clickedCheckbox).prop('checked', !$(clickedCheckbox).prop('checked'));
            }
        }

        function Detail(id) {
            $('#search-index-form').attr('action', '/Segment/Detail');
            $('#Anchor').val('');
            $('#SegmentId').val(id);
            if (ValidateForm()) {
                Submit();
            }
        }

        function Submit() {
            var checkedCategories = [];
            $('.categoryCheckbox:checked').each(function () {
                checkedCategories.push($(this).data('id'));
            });
            $('#SelectedCategoryIds').val(checkedCategories);

            var checkedFuels = [];
            $('.fuelCheckbox:checked').each(function () {
                checkedFuels.push($(this).data('id'));
            });
            $('#SelectedFuelIds').val(checkedFuels);

            var checkedGearboxes = [];
            $('.gearboxCheckbox:checked').each(function () {
                checkedGearboxes.push($(this).data('id'));
            });
            $('#SelectedGearboxIds').val(checkedGearboxes);

            var checkedSeats = [];
            $('.seatCheckbox:checked').each(function () {
                checkedSeats.push($(this).data('id'));
            });
            $('#SelectedSeatNumbers').val(checkedSeats);

            var checkedCampaigns = [];
            $('.campaignCheckbox:checked').each(function () {
                checkedCampaigns.push($(this).data('id'));
            });
            $('#SelectedCampaignIds').val(checkedCampaigns);

            $('#search-index-form').submit();
        }

        function ValidateForm() {
            var valid = true;
            if ($('#PickupLocationId').val() == '' || $('#PickupLocationId').val() == null) {
                $('[aria-labelledby="select2-PickupLocationId-container"]').addClass("is-invalid");
                valid = false;
            } else {
                $('[aria-labelledby="select2-PickupLocationId-container"]').removeClass("is-invalid");
            }
            if ($('#PickupDate').val() == '' || $('#PickupDate').val() == null) {
                $('#PickupDate').addClass("is-invalid");
                valid = false;
            } else {
                $('#PickupDate').removeClass("is-invalid");
            }
            if ($('#PickupTime').val() == '' || $('#PickupTime').val() == null) {
                $('#PickupTime').addClass("is-invalid");
                valid = false;
            } else {
                $('#PickupTime').removeClass("is-invalid");
            }
            if ($('#ReturnLocationId').val() == '' || $('#ReturnLocationId').val() == null) {
                $('[aria-labelledby="select2-ReturnLocationId-container"]').addClass("is-invalid");
                valid = false;
            } else {
                $('[aria-labelledby="select2-ReturnLocationId-container"]').removeClass("is-invalid");
            }
            if ($('#ReturnDate').val() == '' || $('#ReturnDate').val() == null) {
                $('#ReturnDate').addClass("is-invalid");
                valid = false;
            } else {
                $('#ReturnDate').removeClass("is-invalid");
            }
            if ($('#ReturnTime').val() == '' || $('#ReturnTime').val() == null) {
                $('#ReturnTime').addClass("is-invalid");
                valid = false;
            } else {
                $('#ReturnTime').removeClass("is-invalid");
            }
            if (valid) {
                $('#search-index-form #PickupDateTime').val($('#PickupDate').val().split("-").reverse().join("-") + ' ' + $('#PickupTime').val());
                $('#search-index-form #ReturnDateTime').val($('#ReturnDate').val().split("-").reverse().join("-") + ' ' + $('#ReturnTime').val());
                return true;
            } else {
                $("html, body").scrollTop($('#pickup-return-div').offset().top - 100);
                return false;
            }
        }

        $(function () {
            SetActiveMenu('.menu-search');
            var timeoutId;
            $('.select2').select2();
            $('.categoryCheckbox').change(function () {
                clearTimeout(timeoutId);
                timeoutId = setTimeout(function () {
                    Filter('category-div', this);
                }, 1500);
            });
            $('.fuelCheckbox').change(function () {
                clearTimeout(timeoutId);
                timeoutId = setTimeout(function () {
                    Filter('fuel-div', this);
                }, 1500);
            });
            $('.gearboxCheckbox').change(function () {
                clearTimeout(timeoutId);
                timeoutId = setTimeout(function () {
                    Filter('gearbox-div', this);
                }, 1500);
            });
            $('.seatCheckbox').change(function () {
                clearTimeout(timeoutId);
                timeoutId = setTimeout(function () {
                    Filter('seat-div', this);
                }, 1500);
            });
            $('.campaignCheckbox').change(function () {
                clearTimeout(timeoutId);
                timeoutId = setTimeout(function () {
                    Filter('campaign-div', this);
                }, 1500);
            });

            $('#PickupLocationId,#ReturnLocationId').change(function () {
                Filter('pickup-return-div', this);
            });
            $('#PickupDate,#ReturnDate').on('dp.change', function (e) {
                Filter('pickup-return-div', this);
            });
            $('#PickupTime,#ReturnTime').on('dp.change', function (e) {
                clearTimeout(timeoutId);
                timeoutId = setTimeout(function () {
                    Filter('pickup-return-div', this);
                }, 1500);
            });
        });
    </script>
    @if (!string.IsNullOrEmpty(Model.Anchor))
    {
        <script>
            $("html, body").scrollTop($('#@(Model.Anchor)').offset().top - 100);
        </script>
    }
}