@using Microsoft.AspNetCore.Mvc.TagHelpers
@using AMRent.Data.Models.Database
@inject dCore.MultiLanguage.Providers.TranslationProvider TranslationProvider
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@model SearchIndex
@{
    int languageId = HttpContextAccessor.HttpContext.Session.GetInt32("SelectedLanguage") ?? (int)AMRent.Data.Enums.Languages.Portuguese;
    ViewData["Title"] = TranslationProvider.GetTranslation(languageId, "Pesquisa.Titulo");
}

<!-- Breadscrumb Section -->
<div class="breadcrumb-bar"></div>
<!-- /Breadscrumb Section -->

<div class="sortby-sec">
    <div class="container">
        <div class="sorting-div">
            <div class="row d-flex align-items-center">
                <div class="col-xl-12 col-lg-12 col-sm-12 col-12">
                    <div class="product-filter-group">
                        <div class="grid-listview">
                            <ul>
                                @if (Model.ViewLayout == "Grid")
                                {
                                    <li>
                                        <a href="#" class="active">
                                            <i class="feather-grid"></i>
                                        </a>
                                    </li>
                                    <li>
                                        <a onclick="javascript:ChangeView('List');">
                                            <i class="feather-list"></i>
                                        </a>
                                    </li>
                                }
                                else
                                {
                                    <li>
                                        <a onclick="javascript:ChangeView('Grid');" href="#">
                                            <i class="feather-grid"></i>
                                        </a>
                                    </li>
                                    <li>
                                        <a href="#" class="active">
                                            <i class="feather-list"></i>
                                        </a>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Car Grid View -->
<section class="section car-listing">
    <div class="container">
        <div class="row">
            @{
                string divClasses = Model.ViewLayout == "Grid" ? "col-xl-3" : "col-xl-3 col-lg-4 col-sm-12";
            }
            <div class="@divClasses col-12 theiaStickySidebar">
                <form id="search-index-form" asp-controller="Search" asp-action="Index" method="post">
                    <input type="hidden" name="SegmentId" id="SegmentId" />
                    <input type="hidden" asp-for="ViewLayout" />
                    <input type="hidden" asp-for="Anchor" />
                    <div class="sidebar-form">
                        <!-- Pickup and Return -->
                        <div id="pickup-return-div">
                            <div class="sidebar-heading">
                                <h3>@TranslationProvider.GetTranslation(languageId, "Pesquisa.Filtros.Recolha")</h3>
                            </div>
                            <div class="row">
                                <div class="form-custom">
                                    <select asp-for="PickupLocationId" class="select2 form-control" style="width: 100%;" asp-items="ViewBag.PickupLocations"></select>
                                    <span><i class="feather-map-pin"></i></span>
                                </div>
                                <input type="hidden" asp-for="PickupDateTime" />
                                <div class="form-custom date-widget col-sm-7">
                                    <input id="PickupDate" value="@(Model.PickupDateTime.ToString("dd-MM-yyyy"))" type="text" class="form-control datetimepicker" placeholder="@TranslationProvider.GetTranslation(languageId, "Placeholder.Data")">
                                    <span><i class="feather-calendar"></i></span>
                                </div>

                                <div class="form-custom time-widget col-sm-5">
                                    <input id="PickupTime" value="@(Model.PickupDateTime.TimeOfDay)" type="text" class="form-control timepicker" placeholder="@TranslationProvider.GetTranslation(languageId, "Placeholder.Hora")">
                                    <span><i class="feather-clock"></i></span>
                                </div>
                            </div>
                            <div class="sidebar-heading">
                                <h3>@TranslationProvider.GetTranslation(languageId, "Pesquisa.Filtros.Devolucao")</h3>
                            </div>
                            <div class="row">
                                <div class="form-custom">
                                    <select asp-for="ReturnLocationId" class="select2 form-control" style="width: 100%;" asp-items="ViewBag.ReturnLocations"></select>
                                    <span><i class="feather-map-pin"></i></span>
                                </div>
                                <input type="hidden" asp-for="ReturnDateTime" />
                                <div class="form-custom date-widget col-sm-7">
                                    <input id="ReturnDate" value="@(Model.ReturnDateTime.Date.ToString("dd-MM-yyyy"))" type="text" class="form-control datetimepicker" placeholder="@TranslationProvider.GetTranslation(languageId, "Placeholder.Data")">
                                    <span><i class="feather-calendar"></i></span>
                                </div>

                                <div class="form-custom time-widget col-sm-5">
                                    <input id="ReturnTime" value="@(Model.ReturnDateTime.TimeOfDay)" type="text" class="form-control timepicker" placeholder="@TranslationProvider.GetTranslation(languageId, "Placeholder.Hora")">
                                    <span><i class="feather-clock"></i></span>
                                </div>
                            </div>
                            <div class="sidebar-heading">
                                <h3>@Model.Days @TranslationProvider.GetTranslation(languageId, "Segmento.Detalhe.Sidebar.ValorVeiculo.Dias")</h3>
                            </div>
                        </div>
                        @if (Model.PickupReturnValuesAdjusted)
                        {
                            <div class="accordion text-danger">
                                <span>@TranslationProvider.GetTranslation(languageId, "Pesquisa.Filtros.RecolhaDevolucao.AvisoDataHoraAjustada")</span>
                            </div>
                        }
                        <!-- /Pickup and Return -->
                    </div>
                    <div class="sidebar-form mt-4">
                        <!-- Category -->
                        <select asp-for="SelectedCategoryIds" multiple="multiple" style="display:none;">
                            @foreach (KeyValuePair<int, string?> carCategory in Model.CarCategories.OrderBy(x => x.Value))
                            {
                                <option value="@carCategory.Key">@carCategory.Value</option>
                            }
                        </select>
                        @{
                            bool showCategoryFilter = Model.SelectedCategoryIds.Any();
                        }
                        <div class="accordion" id="category-div">
                            <div class="card-header-new" id="headingOne">
                                <h6 class="filter-title">
                                    <a href="javascript:void(0);" class="w-100 @(showCategoryFilter ? "" : "collapsed")" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="@(showCategoryFilter ? "true" : "false")" aria-controls="collapseOne">
                                        @TranslationProvider.GetTranslation(languageId, "Pesquisa.Filtros.Categoria")
                                        <span class="float-end"><i class="fa-solid fa-chevron-down"></i></span>
                                    </a>
                                </h6>
                            </div>
                            <div id="collapseOne" class="collapse @(showCategoryFilter ? "show" : "")" aria-labelledby="headingOne" data-bs-parent="#accordionExample1">
                                <div class="card-body-chat">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="selectBox-cont">
                                                @foreach (KeyValuePair<int, string?> carCategory in Model.CarCategories.OrderBy(x => x.Value))
                                                {
                                                    <label class="custom_check w-100">
                                                        <input type="checkbox" class="categoryCheckbox" data-id="@(carCategory.Key)" @(Model.SelectedCategoryIds.Contains(carCategory.Key) ? "checked='checked'" : "")>
                                                        <span class="checkmark"></span> @(carCategory.Value)
                                                    </label>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- /Category -->
                        <!-- Fuel -->
                        <select asp-for="SelectedFuelIds" multiple="multiple" style="display:none;">
                            @foreach (KeyValuePair<int, string?> carFuel in Model.CarFuels.OrderBy(x => x.Value))
                            {
                                <option value="@carFuel.Key">@carFuel.Value</option>
                            }
                        </select>
                        @{
                            bool showFuelFilter = Model.SelectedFuelIds.Any();
                        }
                        <div class="accordion" id="fuel-div">
                            <div class="card-header-new" id="headingTwo">
                                <h6 class="filter-title">
                                    <a href="javascript:void(0);" class="w-100 @(showFuelFilter ? "" : "collapsed")" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="@(showFuelFilter ? "true" : "false")" aria-controls="collapseTwo">
                                        @TranslationProvider.GetTranslation(languageId, "Pesquisa.Filtros.Combustivel")
                                        <span class="float-end"><i class="fa-solid fa-chevron-down"></i></span>
                                    </a>
                                </h6>
                            </div>
                            <div id="collapseTwo" class="collapse @(showFuelFilter ? "show" : "")" aria-labelledby="headingTwo" data-bs-parent="#accordionExample2">
                                <div class="card-body-chat">
                                    <div class="selectBox-cont">
                                        @foreach (KeyValuePair<int, string?> carFuel in Model.CarFuels.OrderBy(x => x.Value))
                                        {
                                            <label class="custom_check w-100">
                                                <input type="checkbox" class="fuelCheckbox" data-id="@(carFuel.Key)" @(Model.SelectedFuelIds.Contains(carFuel.Key) ? "checked='checked'" : "")>
                                                <span class="checkmark"></span> @(carFuel.Value)
                                            </label>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- /Fuel -->
                        <!-- Gearbox -->
                        <select asp-for="SelectedGearboxIds" multiple="multiple" style="display:none;">
