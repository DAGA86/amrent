@using Microsoft.AspNetCore.Mvc.TagHelpers
@using AMRent.Data.Models.Database
@inject dCore.MultiLanguage.Providers.TranslationProvider TranslationProvider
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@model IEnumerable<AMRent.Data.Models.Database.Reservation>
@{
    int languageId = HttpContextAccessor.HttpContext.Session.GetInt32("SelectedLanguage") ?? (int)AMRent.Data.Enums.Languages.Portuguese;
    ViewData["Title"] = TranslationProvider.GetTranslation(languageId, "MinhaConta.Reservas.Titulo");
}

<!-- Breadscrumb Section -->
<div class="breadcrumb-bar"></div>
<!-- /Breadscrumb Section -->
<!-- Car Grid View -->
<section class="section car-listing booking-section">
    <div class="container">
        <ul class="nav nav-pills booking-tab">
            <li class="nav-item">
                <a class="nav-link" asp-action="Profile" style="text-align: center;">
                    <span>&nbsp;</span>
                    <h5>@(TranslationProvider.GetTranslation(languageId, "MinhaConta.Perfil.Titulo"))</h5>
                    <span>&nbsp;</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link active" href="#">
                    <span>&nbsp;</span>
                    <h5>@ViewData["Title"]</h5>
                    <span>&nbsp;</span>
                </a>
            </li>
        </ul>
        <div class="row">
            <div class="col-12">
                <div class="row">
                    @if (Model.Any())
                    {
                        @foreach (AMRent.Data.Models.Database.Reservation reservation in Model)
                        {
                            <div class="listview-car">
                                <div class="card">
                                    <div class="blog-widget d-flex">
                                        <div class="blog-img">
                                            <a asp-controller="Segment" asp-action="Detail" asp-route-segmentId="@(reservation.CarSegmentId)">
                                                <img src="~/img/segments/@(reservation.CarSegmentId)_list.jpg" asp-append-version="true" class="img-fluid" alt="blog-img">
                                            </a>
                                        </div>
                                        <div class="bloglist-content w-100">
                                            <div class="card-body">
                                                <div class="blog-list-head d-flex">
                                                    <div class="blog-list-title">
                                                        <h3><a asp-controller="Segment" asp-action="Detail" asp-route-segmentId="@(reservation.CarSegmentId)">@(reservation.CarSegment.Translations.First()?.Name)</a></h3>
                                                        <h6>@TranslationProvider.GetTranslation(languageId, "Pesquisa.Segmento.OuSimilar")</h6>
                                                    </div>
                                                    <div class="blog-list-rate">
                                                        @{
                                                            string dailyValue = ((reservation.TotalCostOverride ?? reservation.TotalCost) / reservation.TotalDays).ToString("0.00");
                                                        }
                                                        <div class="price">
                                                            <span class="featured-text">@(dailyValue)€ </span>/ @TranslationProvider.GetTranslation(languageId, "Pesquisa.Segmento.Preco.Dia")<br />
                                                            @TranslationProvider.GetTranslation(languageId, "Pesquisa.Segmento.Preco.Total"): @(reservation.TotalCostOverride ?? reservation.TotalCost)€
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="listing-details-group">
                                                    <ul>
                                                        <li>
                                                            <span><img src="~/img/icons/car-parts-01.svg" alt="Auto"></span>
                                                            <p>@(reservation.CarSegment.CarGearbox.Translations.First()?.Name)</p>
                                                        </li>
                                                        <li>
                                                            <span><img src="~/img/icons/car-parts-03.svg" alt="Petrol"></span>
                                                            <p>@(reservation.CarSegment.CarFuel.Translations.First()?.Name)</p>
                                                        </li>
                                                        <li>
                                                            <span><img src="~/img/icons/car-parts-06.svg" alt="Persons"></span>
                                                            <p>@(reservation.CarSegment.Seats)</p>
                                                        </li>
                                                    </ul>
                                                </div>
                                                @* <div class="blog-list-head list-head-bottom d-flex">
                                                    <div class="blog-list-title">
                                                        <div class="title-bottom">
                                                            <div class="address-info">
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="listing-button">
                                                        <a href="#" onclick="javascript:Detail(@(segment.Id));" type="button" class="btn btn-order"><span><i class="feather-calendar me-2"></i></span>@TranslationProvider.GetTranslation(languageId, "Pesquisa.Segmento.Botao")</a>
                                                    </div>
                                                </div> *@
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12">
                            <div class="listing-item text-danger">@TranslationProvider.GetTranslation(languageId, "MinhaConta.Reservas.SemResultados")</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>